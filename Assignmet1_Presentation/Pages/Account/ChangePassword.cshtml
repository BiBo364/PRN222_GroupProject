@page "/Account/ChangePassword"
@model Assignmet1_Presentation.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row justify-content-center align-items-start g-4 change-password-shell">
    <div class="col-lg-5">
        <div class="page-hero mb-4">
            <div class="hero-badge mb-3">Bảo mật tài khoản</div>
            <h1 class="page-title mb-3">Đổi mật khẩu</h1>
            <p class="page-subtitle mb-4">
                @if (Model.Input.IsForcedChange)
                {
                    <text>Bạn đang đăng nhập bằng mật khẩu mặc định. Hãy đặt mật khẩu mới ngay bây giờ để mở khóa hệ thống.</text>
                }
                else
                {
                    <text>Thay đổi mật khẩu để bảo vệ tài khoản của bạn. Sau khi đổi thành công, bạn sẽ cần đăng nhập lại bằng mật khẩu mới.</text>
                }
            </p>


            <div class="d-flex flex-column gap-3">
                @if (Model.Input.IsForcedChange)
                {
                    <div class="mini-panel change-password-note">
                        <div class="fw-semibold small mb-1">Bắt buộc hoàn tất bước này</div>
                        <div class="text-muted small">Khi chưa đổi mật khẩu, tài khoản chỉ có thể truy cập màn hình này.</div>
                    </div>
                }

                <div class="mini-panel d-flex align-items-start gap-3">
                    <div>
                        <div class="fw-semibold small">Độ dài tối thiểu</div>
                        <div class="text-muted small">Mật khẩu mới phải có ít nhất <strong>6 ký tự</strong> và không trùng với mật khẩu hiện tại.</div>
                    </div>
                </div>

                <div class="mini-panel d-flex align-items-start gap-3">
                    <div>
                        <div class="fw-semibold small">Sau khi hoàn tất</div>
                        <div class="text-muted small">
                            @(Model.Input.IsForcedChange
                                ? "Hệ thống sẽ mở khóa để bạn tiếp tục học tập, trò chuyện và xem tài liệu."
                                : "Hệ thống sẽ tự động đăng xuất sau khi đổi mật khẩu thành công.")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="auth-card">
            <h2 class="h4 mb-1 fw-semibold">Đặt mật khẩu mới</h2>
            <p class="page-subtitle mb-4">
                @(Model.Input.IsForcedChange
                    ? "Nhập mật khẩu mới bên dưới để tiếp tục vào hệ thống."
                    : "Vui lòng nhập mật khẩu hiện tại để xác nhận thay đổi.")
            </p>

            <form method="post" id="changePasswordForm" class="change-password-form">
                @Html.AntiForgeryToken()
                <input asp-for="Input.IsForcedChange" type="hidden" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4">
                        <div asp-validation-summary="ModelOnly"></div>
                    </div>
                }

                @if (!Model.Input.IsForcedChange)
                {
                    <div class="mb-3">
                        <label asp-for="Input.CurrentPassword" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Input.CurrentPassword" type="password" class="form-control form-control-lg" autocomplete="current-password" placeholder="Nhập mật khẩu hiện tại" />
                            <button type="button" class="btn btn-outline-secondary password-toggle" data-password-target="CurrentPassword">Hiện</button>
                        </div>
                        <span asp-validation-for="Input.CurrentPassword" class="text-danger small mt-1 d-block"></span>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Input.NewPassword" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="Input.NewPassword" type="password" class="form-control form-control-lg" autocomplete="new-password" placeholder="Nhập mật khẩu mới" />
                        <button type="button" class="btn btn-outline-secondary password-toggle" data-password-target="NewPassword">Hiện</button>
                    </div>
                    <span asp-validation-for="Input.NewPassword" class="text-danger small mt-1 d-block"></span>
                    <div class="form-text">Nên dùng mật khẩu riêng, dễ nhớ với bạn nhưng khó đoán với người khác.</div>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="Input.ConfirmPassword" type="password" class="form-control form-control-lg" autocomplete="new-password" placeholder="Nhập lại mật khẩu mới" />
                        <button type="button" class="btn btn-outline-secondary password-toggle" data-password-target="ConfirmPassword">Hiện</button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100" id="submitBtn">
                    @(Model.Input.IsForcedChange ? "Lưu mật khẩu và vào hệ thống" : "Đổi mật khẩu")
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    document.querySelectorAll('.password-toggle').forEach(function (button) {
        button.addEventListener('click', function () {
            const input = document.getElementById(button.dataset.passwordTarget);
            if (!input) return;

            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            button.textContent = isPassword ? 'Ẩn' : 'Hiện';
        });
    });

    document.getElementById('changePasswordForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = 'Đang xử lý...';
    });
</script>
}
