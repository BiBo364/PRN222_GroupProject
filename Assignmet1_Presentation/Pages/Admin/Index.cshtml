@page "/Admin/Index"
@model Assignmet1_Presentation.Pages.Admin.IndexModel
@using Assignmet1_Presentation.Models
@{
    ViewData["Title"] = "Quan ly nguoi dung";

    var totalUsers   = Model.ViewModel.Users.Count;
    var activeUsers  = Model.ViewModel.Users.Count(u => u.IsActive);
    var lecturers    = Model.ViewModel.Users.Count(u => u.RoleId == 2);
    var studentCount = Model.ViewModel.Users.Count(u => u.RoleId == 3);
    var unassigned   = Model.ViewModel.Users.Count(u => u.RoleId == 2 && u.SubjectId == null);
}

<div class="d-flex flex-column gap-4">

    <!-- ── HERO ──────────────────────────────────────────────────── -->
    <div class="page-hero d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div>
            <div class="hero-badge mb-2">
                <i data-lucide="shield-check" class="icon-sm"></i> Quan tri he thong
            </div>
            <h1 class="page-title mb-1">Quan ly nguoi dung</h1>
            <p class="page-subtitle">Xem, phan cong mon hoc va quan ly trang thai tai khoan toan he thong.</p>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
            <a asp-page="/Admin/ImportUsers" class="btn btn-primary">
                <i data-lucide="file-up" class="icon-sm"></i> Import nguoi dung
            </a>
        </div>
    </div>

    <!-- ── ALERT MESSAGES ────────────────────────────────────────── -->

    <!-- ── STATS ROW ──────────────────────────────────────────────── -->
    <div class="row g-3 stagger-children">
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value" style="background:var(--grad-cool);-webkit-background-clip:text;-webkit-text-fill-color:transparent">@totalUsers</div>
                <div class="stat-label">Tong nguoi dung</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value" style="background:var(--grad-accent);-webkit-background-clip:text;-webkit-text-fill-color:transparent">@activeUsers</div>
                <div class="stat-label">Dang hoat dong</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value" style="background:var(--grad-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent">@lecturers</div>
                <div class="stat-label">Giang vien</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value" style="background:var(--grad-warm);-webkit-background-clip:text;-webkit-text-fill-color:transparent">@unassigned</div>
                <div class="stat-label">GV chua co mon</div>
            </div>
        </div>
    </div>

    <!-- ── FILTER / SEARCH ───────────────────────────────────────── -->
    <div class="surface-card">
        <div class="d-flex align-items-center gap-2 mb-3">
            <i data-lucide="filter" class="icon-sm" style="color:var(--primary)"></i>
            <span class="fw-semibold" style="font-size:.9rem;color:var(--text-sec)">Bo loc va tim kiem</span>
        </div>
        <form method="get" asp-page="/Admin/Index" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">
                    <i data-lucide="search" class="icon-sm"></i> Tim kiem
                </label>
                <input type="text" name="search" value="@Model.ViewModel.SearchTerm"
                       class="form-control" placeholder="Ten, email, username..." />
            </div>
            <div class="col-md-3">
                <label class="form-label">
                    <i data-lucide="shield" class="icon-sm"></i> Vai tro
                </label>
                <select name="roleId" class="form-select">
                    <option value="">Tat ca vai tro</option>
                    <option value="1" selected="@(Model.ViewModel.FilterRoleId == 1)">Admin</option>
                    <option value="2" selected="@(Model.ViewModel.FilterRoleId == 2)">Giang vien</option>
                    <option value="3" selected="@(Model.ViewModel.FilterRoleId == 3)">Sinh vien</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">
                    <i data-lucide="book-open" class="icon-sm"></i> Mon hoc
                </label>
                <select name="subjectId" class="form-select">
                    <option value="">Tat ca mon hoc</option>
                    @foreach (var s in Model.ViewModel.Subjects)
                    {
                        <option value="@s.Id" selected="@(Model.ViewModel.FilterSubjectId == s.Id)">@s.Code — @s.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i data-lucide="search" class="icon-sm"></i> Loc
                </button>
                <a asp-page="/Admin/Index" class="btn btn-outline-secondary flex-fill">
                    <i data-lucide="rotate-ccw" class="icon-sm"></i>
                </a>
            </div>
        </form>
    </div>

    <!-- ── TABLE ─────────────────────────────────────────────────── -->
    <div class="surface-card p-0 overflow-hidden">
        <div class="card-header-row">
            <h2 class="card-header-title">
                <i data-lucide="users" class="icon-sm me-1" style="color:var(--primary)"></i>
                Danh sach nguoi dung — @Model.ViewModel.Users.Count ket qua
            </h2>
        </div>

        @if (Model.ViewModel.Users.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i data-lucide="users" style="width:56px;height:56px;color:var(--text-faint)"></i>
                </div>
                <div class="empty-state-title">Khong tim thay nguoi dung</div>
                <div class="empty-state-desc">Thu thay doi bo loc de xem tat ca nguoi dung trong he thong.</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle" id="usersTable">
                    <thead>
                        <tr>
                            <th class="ps-4">Nguoi dung</th>
                            <th>Vai tro</th>
                            <th>Mon hoc duoc phan cong</th>
                            <th>Trang thai</th>
                            <th>Dang nhap lan cuoi</th>
                            <th class="pe-4 text-end">Hanh dong</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.ViewModel.Users)
                        {
                            string roleColor = "#64748b", roleIcon = "user", roleLbl = "Unknown";
                                if (user.RoleId == 1) { roleColor = "#f59e0b"; roleIcon = "shield-check"; roleLbl = "Admin"; }
                                else if (user.RoleId == 2) { roleColor = "#6366f1"; roleIcon = "graduation-cap"; roleLbl = "Giang vien"; }
                                else if (user.RoleId == 3) { roleColor = "#10b981"; roleIcon = "user"; roleLbl = "Sinh vien"; }
                                var initials = (user.FullName?.Length > 0
                                    ? user.FullName[0]
                                    : user.Username[0]).ToString().ToUpper();
                            <tr>
                                <!-- Avatar + info -->
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="user-avatar-circle" style="background:linear-gradient(135deg,@roleColor,@(roleColor)aa)">
                                            @initials
                                        </div>
                                        <div>
                                            <div class="fw-semibold" style="font-size:.9rem;color:var(--text)">
                                                @(user.FullName ?? user.Username)
                                            </div>
                                            <div style="font-size:.78rem;color:var(--text-muted)">@user.Email</div>
                                            <div style="font-size:.72rem;color:var(--text-faint)">@@@user.Username</div>
                                        </div>
                                    </div>
                                </td>

                                <!-- Role badge -->
                                <td>
                                    <span class="role-badge" style="background:@(roleColor)18;border:1px solid @(roleColor)33;color:@roleColor">
                                        <i data-lucide="@roleIcon" class="icon-xs"></i>
                                        @roleLbl
                                    </span>
                                </td>

                                <!-- Subject assignment -->
                                <td>
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        @if (user.SubjectId.HasValue)
                                        {
                                            <span class="status-chip primary" title="@user.SubjectName">
                                                <i data-lucide="book-open" class="icon-xs"></i>
                                                @user.SubjectCode
                                            </span>
                                        }
                                        else if (user.RoleId == 2)
                                        {
                                            <span style="color:var(--text-faint);font-size:.85rem">Chua phan cong</span>
                                        }
                                        else
                                        {
                                            <span style="color:var(--text-faint);font-size:.85rem">Khong ap dung</span>
                                        }

                                        @if (user.RoleId == 2)
                                        {
                                            <!-- Assign dropdown -->
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                                                        data-bs-toggle="dropdown" title="Phan cong mon hoc"
                                                        style="height:24px;min-width:28px">
                                                    <i data-lucide="chevrons-up-down" class="icon-xs"></i>
                                                </button>
                                                <ul class="dropdown-menu" style="min-width:240px">
                                                    <li>
                                                        <span class="dropdown-header" style="font-size:.72rem;color:var(--text-faint);text-transform:uppercase;letter-spacing:.06em">
                                                            Phan cong mon hoc
                                                        </span>
                                                    </li>
                                                    <li>
                                                        <form asp-page-handler="AssignSubject" method="post" class="px-3 pb-2 pt-1">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="userId" value="@user.Id" />
                                                            <select name="subjectId" class="form-select form-select-sm mb-2">
                                                                <option value="">— Bo mon hoc —</option>
                                                                @foreach (var s in Model.ViewModel.Subjects)
                                                                {
                                                                    var isCurrentUserSubject = user.SubjectId == s.Id;
                                                                    Model.ViewModel.TeacherBySubjectId.TryGetValue(s.Id, out var assignedTeacher);
                                                                    var isTakenByOther = assignedTeacher != null && !isCurrentUserSubject;
                                                                    <option value="@s.Id"
                                                                            selected="@isCurrentUserSubject"
                                                                            disabled="@isTakenByOther">
                                                                        @s.Code — @s.Name@(isTakenByOther ? $" (da gan: {assignedTeacher})" : "")
                                                                    </option>
                                                                }
                                                            </select>
                                                            <button type="submit" class="btn btn-primary btn-sm w-100">
                                                                <i data-lucide="save" class="icon-sm"></i> Luu phan cong
                                                            </button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </td>

                                <!-- Status -->
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="status-chip success">
                                            <i data-lucide="check-circle" class="icon-xs"></i> Hoat dong
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-chip danger">
                                            <i data-lucide="ban" class="icon-xs"></i> Vo hieu
                                        </span>
                                    }
                                </td>

                                <!-- Last login -->
                                <td>
                                    <span style="font-size:.82rem;color:var(--text-muted)">
                                        @(user.LastLoginAt.HasValue
                                            ? user.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm")
                                            : "Chua dang nhap")
                                    </span>
                                </td>

                                <!-- Actions -->
                                <td class="pe-4 text-end">
                                    <form asp-page-handler="ToggleStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="button"
                                                class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success") btn-toggle-status"
                                                data-action="@(user.IsActive ? "vo hieu hoa" : "kich hoat")"
                                                data-name="@(user.FullName ?? user.Username)"
                                                title="@(user.IsActive ? "Vo hieu hoa tai khoan" : "Kich hoat tai khoan")">
                                            <i data-lucide="@(user.IsActive ? "lock" : "unlock")" class="icon-sm"></i>
                                            @(user.IsActive ? "Vo hieu" : "Kich hoat")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.ViewModel.TotalPages > 1)
            {
                <div class="px-4 py-3 d-flex align-items-center justify-content-between flex-wrap gap-2"
                     style="border-top:1px solid var(--surface-border)">
                    <div style="font-size:.82rem;color:var(--text-muted)">
                        Hien thi
                        @((Model.ViewModel.CurrentPage - 1) * Model.ViewModel.PageSize + 1)
                        &ndash;
                        @((Model.ViewModel.CurrentPage - 1) * Model.ViewModel.PageSize + Model.ViewModel.Users.Count)
                        trong @Model.ViewModel.TotalItems nguoi dung
                    </div>
                    <nav aria-label="Phan trang">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.ViewModel.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link"
                                   asp-page="/Admin/Index"
                                   asp-route-page="@(Model.ViewModel.CurrentPage - 1)"
                                   asp-route-search="@Model.ViewModel.SearchTerm"
                                   asp-route-roleId="@Model.ViewModel.FilterRoleId"
                                   asp-route-subjectId="@Model.ViewModel.FilterSubjectId">
                                    <i data-lucide="chevron-left" class="icon-xs"></i>
                                </a>
                            </li>
                            @for (int i = 1; i <= Model.ViewModel.TotalPages; i++)
                            {
                                <li class="page-item @(Model.ViewModel.CurrentPage == i ? "active" : "")">
                                    <a class="page-link"
                                       asp-page="/Admin/Index"
                                       asp-route-page="@i"
                                       asp-route-search="@Model.ViewModel.SearchTerm"
                                       asp-route-roleId="@Model.ViewModel.FilterRoleId"
                                       asp-route-subjectId="@Model.ViewModel.FilterSubjectId">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.ViewModel.CurrentPage == Model.ViewModel.TotalPages ? "disabled" : "")">
                                <a class="page-link"
                                   asp-page="/Admin/Index"
                                   asp-route-page="@(Model.ViewModel.CurrentPage + 1)"
                                   asp-route-search="@Model.ViewModel.SearchTerm"
                                   asp-route-roleId="@Model.ViewModel.FilterRoleId"
                                   asp-route-subjectId="@Model.ViewModel.FilterSubjectId">
                                    <i data-lucide="chevron-right" class="icon-xs"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

<!-- ── Modal: Confirm Toggle Status ──────────────────────────── -->
<div class="modal fade" id="toggleStatusModal" tabindex="-1" aria-labelledby="toggleStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="toggleStatusModalLabel">
                    <i data-lucide="alert-circle" class="icon-md me-2" style="color:var(--amber)"></i>
                    Xac nhan thay doi
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Dong"></button>
            </div>
            <div class="modal-body" style="font-size:.9rem;color:var(--text-sec)">
                Ban co chac muon <strong id="toggleActionNameBody"></strong> tai khoan
                <strong id="toggleUserName" style="color:var(--primary)"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Huy bo</button>
                <button type="button" class="btn btn-primary" id="confirmToggleBtn">Xac nhan</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            let formToSubmit = null;
            const modalEl = document.getElementById('toggleStatusModal');
            const toggleModal = modalEl ? new bootstrap.Modal(modalEl) : null;

            document.querySelectorAll('.btn-toggle-status').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    formToSubmit = e.target.closest('form');
                    const action = btn.getAttribute('data-action');
                    const name   = btn.getAttribute('data-name');
                    document.getElementById('toggleActionNameBody').textContent = action;
                    document.getElementById('toggleUserName').textContent = name;
                    if (toggleModal) toggleModal.show();
                });
            });

            const confirmBtn = document.getElementById('confirmToggleBtn');
            if (confirmBtn) {
                confirmBtn.addEventListener('click', () => {
                    if (formToSubmit) formToSubmit.submit();
                    if (toggleModal) toggleModal.hide();
                });
            }
        });
    </script>
}
