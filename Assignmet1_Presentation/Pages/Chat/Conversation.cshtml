@page "/Chat/Conversation/{id}"
@model Assignmet1_Presentation.Pages.Chat.ConversationModel
@{
    ViewData["Title"] = Model.ViewModel.Session.Title ?? "Chat";
    var session = Model.ViewModel.Session;
}

<section class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="hero-badge mb-3">Conversation</div>
            <h1 class="page-title mb-2">@session.Title</h1>
            @if (!string.IsNullOrWhiteSpace(session.SubjectCode) || !string.IsNullOrWhiteSpace(session.SubjectName))
            {
                <p class="page-subtitle mb-0">@session.SubjectCode - @session.SubjectName</p>
            }
        </div>
        <a class="btn btn-outline-light btn-sm" asp-page="/Chat/Index" asp-route-subjectId="@Model.ViewModel.SelectedSubjectId">All chats</a>
    </div>
</section>

@if (Model.ViewModel.QuotaStatus is not null)
{
    <div id="chatQuotaStatus" class="alert @(Model.ViewModel.QuotaStatus.IsPlus ? "alert-success" : Model.ViewModel.QuotaStatus.IsAllowed ? "alert-info" : "alert-warning")">
        @Model.ViewModel.QuotaStatus.Message
        @if (!Model.ViewModel.QuotaStatus.IsPlus)
        {
            <a class="ms-2" asp-page="/Subscription/Index">Nang cap Plus</a>
        }
    </div>
}
else
{
    <div id="chatQuotaStatus" class="d-none"></div>
}

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div id="chatError" class="alert alert-danger d-none" role="alert"></div>

<div id="chatMessages" class="chat-shell scroll-panel mb-3" data-session-id="@session.Id">
    <p id="chatEmptyState" class="page-subtitle mb-0 @(session.Messages.Any() ? "d-none" : string.Empty)">
        Ask a question about the indexed documents for this subject.
    </p>

    @foreach (var message in session.Messages)
    {
        var isUser = message.Role == "user";
        <div class="mb-3 d-flex @(isUser ? "justify-content-end" : "justify-content-start")">
            <div class="chat-message @(isUser ? "user" : "assistant")">
                <div class="small fw-semibold mb-1">@(isUser ? "You" : "Assistant")</div>
                <div class="chat-message-body">@message.Content</div>

                @if (!isUser && message.Citations.Any())
                {
                    <hr class="my-2" />
                    <div class="small">
                        <strong>Sources:</strong>
                        <ul class="mb-0 ps-3">
                            @foreach (var cite in message.Citations)
                            {
                                <li>
                                    @cite.DocumentName
                                    @(cite.SlideNumber.HasValue ? $"(slide {cite.SlideNumber})" : string.Empty)
                                    <span class="text-muted">- score @cite.Score</span>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    }
</div>

<div class="surface-card">
    <form id="chatForm" asp-page-handler="Ask" asp-route-id="@session.Id" method="post">
        <div asp-validation-summary="All" class="text-danger mb-2"></div>
        <div class="input-group input-group-lg">
            <input asp-for="ViewModel.Question" class="form-control" placeholder="Ask about the course materials..." autocomplete="off" />
            <button id="chatSubmitButton" type="submit" class="btn btn-primary">Send</button>
        </div>
        <span asp-validation-for="ViewModel.Question" class="text-danger"></span>
        <div id="chatPendingHint" class="form-text mt-2 d-none">
            Assistant is reviewing the indexed materials. You can keep reading the conversation while the answer is loading.
        </div>
        <div class="form-text mt-2">Answers use RAG retrieval from indexed documents only.</div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const form = document.getElementById("chatForm");
            const input = document.getElementById("ViewModel_Question");
            const submitButton = document.getElementById("chatSubmitButton");
            const messages = document.getElementById("chatMessages");
            const emptyState = document.getElementById("chatEmptyState");
            const errorBox = document.getElementById("chatError");
            const pendingHint = document.getElementById("chatPendingHint");
            const quotaBox = document.getElementById("chatQuotaStatus");

            if (!form || !input || !submitButton || !messages) {
                return;
            }

            let isPending = false;

            const scrollToBottom = () => {
                messages.scrollTop = messages.scrollHeight;
            };

            const hideEmptyState = () => {
                if (emptyState) {
                    emptyState.classList.add("d-none");
                }
            };

            const setError = (message) => {
                if (!errorBox) {
                    return;
                }

                if (!message) {
                    errorBox.textContent = "";
                    errorBox.classList.add("d-none");
                    return;
                }

                errorBox.textContent = message;
                errorBox.classList.remove("d-none");
            };

            const setQuotaStatus = (quota) => {
                if (!quotaBox || !quota) {
                    return;
                }

                quotaBox.classList.remove("d-none", "alert-success", "alert-info", "alert-warning");
                quotaBox.classList.add(quota.isPlus ? "alert-success" : quota.isAllowed ? "alert-info" : "alert-warning");
                quotaBox.textContent = quota.message || "";
            };

            const createMessageElement = (role, content, options = {}) => {
                const wrapper = document.createElement("div");
                wrapper.className = `mb-3 d-flex ${role === "user" ? "justify-content-end" : "justify-content-start"}`;

                const bubble = document.createElement("div");
                bubble.className = `chat-message ${role === "user" ? "user" : "assistant"}`;

                if (options.pending) {
                    bubble.classList.add("assistant-pending");
                }

                const title = document.createElement("div");
                title.className = "small fw-semibold mb-1";
                title.textContent = role === "user" ? "You" : "Assistant";

                const body = document.createElement("div");
                body.className = "chat-message-body";

                if (options.pending) {
                    const text = document.createElement("div");
                    text.textContent = "Hay doi toi mot chut, toi dang tim kiem thong tin lien quan.";
                    body.appendChild(text);

                    const dots = document.createElement("div");
                    dots.className = "typing-dots mt-2";
                    dots.innerHTML = "<span></span><span></span><span></span>";
                    body.appendChild(dots);
                } else {
                    body.textContent = content ?? "";
                }

                bubble.appendChild(title);
                bubble.appendChild(body);
                wrapper.appendChild(bubble);

                if (options.citations && options.citations.length) {
                    appendCitations(bubble, options.citations);
                }

                return { wrapper, bubble, body };
            };

            const appendCitations = (bubble, citations) => {
                const divider = document.createElement("hr");
                divider.className = "my-2";

                const box = document.createElement("div");
                box.className = "small";

                const strong = document.createElement("strong");
                strong.textContent = "Sources:";

                const list = document.createElement("ul");
                list.className = "mb-0 ps-3";

                citations.forEach((citation) => {
                    const item = document.createElement("li");
                    const parts = [citation.documentName];

                    if (citation.slideNumber !== null && citation.slideNumber !== undefined) {
                        parts.push(`(slide ${citation.slideNumber})`);
                    }

                    item.append(document.createTextNode(parts.join(" ")));

                    const score = document.createElement("span");
                    score.className = "text-muted";
                    score.textContent = ` - score ${citation.score}`;
                    item.appendChild(score);
                    list.appendChild(item);
                });

                box.appendChild(strong);
                box.appendChild(list);
                bubble.appendChild(divider);
                bubble.appendChild(box);
            };

            scrollToBottom();

            form.addEventListener("submit", async (event) => {
                event.preventDefault();

                if (isPending) {
                    return;
                }

                const question = input.value.trim();
                if (!question) {
                    input.focus();
                    setError("Please enter a question.");
                    return;
                }

                setError("");
                hideEmptyState();
                isPending = true;
                submitButton.disabled = true;
                input.readOnly = true;
                pendingHint?.classList.remove("d-none");

                const userMessage = createMessageElement("user", question);
                const assistantMessage = createMessageElement("assistant", "", { pending: true });

                messages.appendChild(userMessage.wrapper);
                messages.appendChild(assistantMessage.wrapper);
                scrollToBottom();

                const formData = new FormData(form);

                try {
                    const response = await fetch(form.action, {
                        method: "POST",
                        body: formData,
                        headers: {
                            "X-Requested-With": "XMLHttpRequest",
                            "Accept": "application/json"
                        }
                    });

                    const payload = await response.json().catch(() => ({}));

                    if (!response.ok) {
                        throw new Error(payload.error || "Unable to get an answer right now.");
                    }

                    assistantMessage.bubble.classList.remove("assistant-pending");
                    assistantMessage.body.textContent = payload.answer || "No answer was returned.";

                    if (Array.isArray(payload.citations) && payload.citations.length > 0) {
                        appendCitations(assistantMessage.bubble, payload.citations);
                    }

                    if (payload.quota) {
                        setQuotaStatus(payload.quota);
                    }

                    input.value = "";
                } catch (error) {
                    assistantMessage.bubble.classList.remove("assistant-pending");
                    assistantMessage.bubble.classList.add("assistant-error");
                    assistantMessage.body.textContent = error instanceof Error
                        ? error.message
                        : "Something went wrong while retrieving the answer.";
                    setError(assistantMessage.body.textContent);
                } finally {
                    isPending = false;
                    submitButton.disabled = false;
                    input.readOnly = false;
                    pendingHint?.classList.add("d-none");
                    input.focus();
                    scrollToBottom();
                }
            });
        })();
    </script>
}
