@page "/Chat/Index"
@model Assignmet1_Presentation.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "Chat";
    var selectedSubject = Model.ViewModel.AvailableSubjects.FirstOrDefault(subject => subject.Id == Model.ViewModel.SelectedSubjectId);
}

<section class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="hero-badge mb-3">RAG chat</div>
            <h1 class="page-title">Chat &amp; Q&amp;A</h1>
            @if (selectedSubject is not null)
            {
                <p class="page-subtitle">Subject: <strong>@selectedSubject.Code</strong> - @selectedSubject.Name</p>
            }
            else
            {
                <p class="page-subtitle">Choose a subject with indexed documents before starting a conversation.</p>
            }
        </div>
    </div>
</section>

<div class="alert alert-info">
    Answers are limited to indexed course documents and include source citations from uploaded materials.
</div>

@if (Model.ViewModel.QuotaStatus is not null)
{
    <div class="alert @(Model.ViewModel.QuotaStatus.IsPlus ? "alert-success" : Model.ViewModel.QuotaStatus.IsAllowed ? "alert-info" : "alert-warning")">
        @Model.ViewModel.QuotaStatus.Message
        @if (!Model.ViewModel.QuotaStatus.IsPlus)
        {
            <a class="ms-2" asp-page="/Subscription/Index">Xem goi Plus</a>
        }
    </div>
}


<div class="surface-card mb-4">
    <form method="get" asp-page="/Chat/Index" class="row g-3 align-items-end chat-filter-form">
        <div class="col-12 col-md-8">
            <label class="form-label" for="subjectId">Subject</label>
            <select class="form-select form-select-lg" id="subjectId" name="subjectId">
                <option value="">Select a subject</option>
                @foreach (var subject in Model.ViewModel.AvailableSubjects)
                {
                    if (subject.Id == Model.ViewModel.SelectedSubjectId)
                    {
                        <option value="@subject.Id" selected>@subject.Code - @subject.Name</option>
                    }
                    else
                    {
                        <option value="@subject.Id">@subject.Code - @subject.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-12 col-md-4 d-grid">
            <button type="submit" class="btn btn-outline-primary btn-lg btn-load-chats">Load chats</button>
        </div>
    </form>
</div>

<div class="d-flex justify-content-end mb-3">
    <a id="newChatBtn"
       class="btn btn-primary @(Model.ViewModel.SelectedSubjectId.HasValue ? null : "disabled")"
       asp-page="/Chat/New"
       asp-route-subjectId="@Model.ViewModel.SelectedSubjectId"
       aria-disabled="@(Model.ViewModel.SelectedSubjectId.HasValue ? "false" : "true")">chat mới</a>
</div>

@if (!Model.ViewModel.Sessions.Any())
{
    <div class="content-panel text-center py-5">
        <h3 class="h5 mb-2">No conversations yet</h3>
        @if (Model.ViewModel.SelectedSubjectId.HasValue)
        {
            <p class="page-subtitle mb-0">Start a new chat to ask questions about this subject's indexed materials.</p>
        }
        else
        {
            <p class="page-subtitle mb-0">Select a subject above to view or start conversations.</p>
        }
    </div>
}
else
{
    <div class="surface-card p-0 overflow-hidden">
        @foreach (var session in Model.ViewModel.Sessions)
        {
            <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
               asp-page="/Chat/Conversation" asp-route-id="@session.Id">
                <div>
                    <div class="fw-semibold text-white">@session.Title</div>
                    <small>Updated @session.UpdatedAt?.ToString("g")</small>
                </div>
                <span class="status-chip badge-soft">open</span>
            </a>
        }
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const subjectSelect = document.getElementById('subjectId');
            const newChatBtn = document.getElementById('newChatBtn');
            const newChatBaseUrl = '@Url.Page("/Chat/New")';

            function updateNewChatButton() {
                const subjectId = subjectSelect.value;
                if (subjectId) {
                    newChatBtn.href = `${newChatBaseUrl}?subjectId=${encodeURIComponent(subjectId)}`;
                    newChatBtn.classList.remove('disabled');
                    newChatBtn.setAttribute('aria-disabled', 'false');
                } else {
                    newChatBtn.removeAttribute('href');
                    newChatBtn.classList.add('disabled');
                    newChatBtn.setAttribute('aria-disabled', 'true');
                }
            }

            subjectSelect.addEventListener('change', () => {
                updateNewChatButton();
                subjectSelect.form?.submit();
            });

            newChatBtn.addEventListener('click', (event) => {
                if (!subjectSelect.value) {
                    event.preventDefault();
                }
            });

            updateNewChatButton();
        });
    </script>
}
