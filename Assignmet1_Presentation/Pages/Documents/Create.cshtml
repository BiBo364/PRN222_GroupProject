@page "/Documents/Create"
@model Assignmet1_Presentation.Pages.Documents.CreateModel
@{
    ViewData["Title"] = "Create file entry";
}

<section class="page-hero mb-4">
    <div class="hero-badge mb-3">Create</div>
    <h1 class="page-title mb-2">Create file entry</h1>
    @if (Model.ViewModel.Subject is not null)
    {
        <p class="page-subtitle">Subject: <strong>@Model.ViewModel.Subject.Code</strong> — @Model.ViewModel.Subject.Name</p>
    }
</section>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="surface-card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input asp-for="ViewModel.SubjectId" type="hidden" />

        @if (Model.ViewModel.Subject is not null)
        {
            <div class="alert alert-info">
                Creating a file entry for <strong>@Model.ViewModel.Subject.Code</strong> — @Model.ViewModel.Subject.Name.
            </div>
        }

        <div class="mb-3">
            <label asp-for="ViewModel.OriginalName" class="form-label"></label>
            <input asp-for="ViewModel.OriginalName" class="form-control" />
            <span asp-validation-for="ViewModel.OriginalName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ViewModel.FileType" class="form-label"></label>
            <select asp-for="ViewModel.FileType" class="form-select">
                <option value="pdf">PDF</option>
                <option value="docx">DOCX</option>
                <option value="pptx">PPTX</option>
            </select>
        </div>

        @if (Model.ViewModel.ChapterOptions.Any())
        {
            <div class="mb-3">
                <label asp-for="ViewModel.ChapterId" class="form-label"></label>
                <select asp-for="ViewModel.ChapterId" asp-items="Model.ViewModel.ChapterOptions" class="form-select">
                    <option value="">-- Select chapter --</option>
                </select>
                <span asp-validation-for="ViewModel.ChapterId" class="text-danger"></span>
            </div>
        }

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary">Create</button>
            <a asp-page="/Documents/Index" class="btn btn-outline-light">Back to subjects</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
