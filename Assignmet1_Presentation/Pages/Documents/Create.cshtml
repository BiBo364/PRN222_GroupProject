@page "/Documents/Create"
@model Assignmet1_Presentation.Pages.Documents.CreateModel
@{
    ViewData["Title"] = "Tạo tài liệu mới";
}

<section class="page-hero mb-4">
    <div class="hero-badge mb-3"><i data-lucide="plus-circle" class="icon-sm"></i> Tạo mới</div>
    <h1 class="page-title mb-2">Tạo tài liệu rỗng</h1>
    @if (Model.ViewModel.Subject is not null)
    {
        <p class="page-subtitle">Môn học: <strong>@Model.ViewModel.Subject.Code</strong> — @Model.ViewModel.Subject.Name</p>
    }
</section>


<div class="surface-card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input asp-for="ViewModel.SubjectId" type="hidden" />

        @if (Model.ViewModel.Subject is not null)
        {
            <div class="alert alert-info">
                Đang tạo tài liệu mới cho môn học <strong>@Model.ViewModel.Subject.Code</strong> — @Model.ViewModel.Subject.Name.
            </div>
        }

        <div class="mb-3">
            <label asp-for="ViewModel.OriginalName" class="form-label">Tên tài liệu</label>
            <input asp-for="ViewModel.OriginalName" class="form-control" />
            <span asp-validation-for="ViewModel.OriginalName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ViewModel.FileType" class="form-label">Loại tệp</label>
            <select asp-for="ViewModel.FileType" class="form-select">
                <option value="pdf">PDF</option>
                <option value="docx">DOCX</option>
                <option value="pptx">PPTX</option>
            </select>
        </div>

        @if (Model.ViewModel.ChapterOptions.Any())
        {
            <div class="mb-3">
                <label asp-for="ViewModel.ChapterId" class="form-label">Chương</label>
                <select asp-for="ViewModel.ChapterId" asp-items="Model.ViewModel.ChapterOptions" class="form-select">
                    <option value="">-- Chọn chương --</option>
                </select>
                <span asp-validation-for="ViewModel.ChapterId" class="text-danger"></span>
            </div>
        }

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary"><i data-lucide="check" class="icon-sm me-2"></i> Tạo mới</button>
            <a asp-page="/Documents/Index" class="btn btn-outline-secondary"><i data-lucide="arrow-left" class="icon-sm me-2"></i> Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
