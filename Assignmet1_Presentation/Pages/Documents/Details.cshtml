@page "/Documents/Details/{id:int}"
@model Assignmet1_Presentation.Pages.Documents.DetailsModel
@{
    ViewData["Title"] = Model.ViewModel.OriginalName;
}

<section class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
        <div>
            <div class="hero-badge mb-3"><i data-lucide="file-text" class="icon-sm"></i> Chi tiết tài liệu</div>
            <h1 class="page-title mb-2">@Model.ViewModel.OriginalName</h1>
            <p class="page-subtitle mb-0">
                <span class="status-chip badge-soft me-2">@Model.ViewModel.FileType.ToUpper()</span>
                @if (Model.ViewModel.IsSlideDeck)
                {
                    <span class="status-chip badge-soft me-2">@Model.ViewModel.Chunks.Count trang slide</span>
                }
                @if (Model.ViewModel.ChapterNumber is not null)
                {
                    <span>Chương @Model.ViewModel.ChapterNumber: @Model.ViewModel.ChapterTitle</span>
                }
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" asp-page="/Documents/Index"><i data-lucide="arrow-left" class="icon-sm me-2"></i> Quay lại</a>
            @if (Model.ViewModel.CanReindex && Model.ViewModel.NeedsReindex)
            {
                <form asp-page-handler="Reindex" asp-route-id="@Model.ViewModel.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning"><i data-lucide="refresh-cw" class="icon-sm me-2"></i> Lập chỉ mục lại</button>
                </form>
            }
            @if (Model.ViewModel.CanDelete)
            {
                <form asp-page-handler="Delete" asp-route-id="@Model.ViewModel.Id" method="post" class="d-inline" id="deleteDocForm">
                    @Html.AntiForgeryToken()
                    @if (Model.ViewModel.SubjectId.HasValue)
                    {
                        <input type="hidden" name="returnSubjectId" value="@Model.ViewModel.SubjectId.Value" />
                    }
                    <button type="button" class="btn btn-outline-danger btn-delete-confirm" data-item-name="tài liệu này"><i data-lucide="trash-2" class="icon-sm me-2"></i> Xóa</button>
                </form>
            }
        </div>
    </div>
</section>


<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i data-lucide="activity" class="icon-sm me-1"></i> Trạng thái</div>
            <div class="stat-value fs-6 @(Model.ViewModel.Status == "indexed" ? "text-success" : Model.ViewModel.Status == "failed" ? "text-danger" : "text-warning")">@Model.ViewModel.Status</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i data-lucide="layers" class="icon-sm me-1"></i> @(Model.ViewModel.IsSlideDeck ? "Trang slide" : "Chunks")</div>
            <div class="stat-value fs-6">@Model.ViewModel.Chunks.Count</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i data-lucide="user" class="icon-sm me-1"></i> Người tải lên</div>
            <div class="stat-value fs-6">@(Model.ViewModel.UploadedByName ?? "—")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label"><i data-lucide="clock" class="icon-sm me-1"></i> Ngày lập chỉ mục</div>
            <div class="stat-value fs-6 text-muted">@(Model.ViewModel.IndexedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
        </div>
    </div>
</div>

@if (Model.ViewModel.CanEdit)
{
    <section class="surface-card p-4 mb-4">
        <div class="d-flex align-items-center gap-2 mb-3">
            <i data-lucide="pencil" class="icon-sm text-primary"></i>
            <h2 class="card-header-title mb-0">Chinh sua tai lieu</h2>
        </div>
        <form asp-page-handler="Update" asp-route-id="@Model.ViewModel.Id" method="post" class="row g-3 align-items-end">
            @Html.AntiForgeryToken()
            <div class="col-12 col-lg-7">
                <label class="form-label fw-semibold" for="documentOriginalName">Ten tai lieu</label>
                <input id="documentOriginalName"
                       name="originalName"
                       class="form-control"
                       value="@Model.ViewModel.OriginalName"
                       maxlength="500"
                       required />
            </div>
            <div class="col-12 col-lg-3">
                <label class="form-label fw-semibold" for="documentChapterId">Chuong</label>
                <select id="documentChapterId" name="chapterId" class="form-select">
                    <option value="">Khong gan chuong</option>
                    @foreach (var option in Model.ViewModel.ChapterOptions)
                    {
                        <option value="@option.Value" selected="@option.Selected">@option.Text</option>
                    }
                </select>
            </div>
            <div class="col-12 col-lg-2 d-grid">
                <button type="submit" class="btn btn-primary">
                    <i data-lucide="save" class="icon-sm"></i> Luu
                </button>
            </div>
        </form>
    </section>
}

<section class="document-reader mb-4">
    <div class="document-reader-header">
        <div>
            <div class="reader-kicker">
                <i data-lucide="book-open-text" class="icon-sm"></i>
                @(Model.ViewModel.IsSlideDeck ? "Slide deck" : "Indexed content")
            </div>
            <h4 class="reader-title mb-0">@(Model.ViewModel.IsSlideDeck ? "Nội dung slide" : "Nội dung lập chỉ mục")</h4>
        </div>
        <div class="reader-summary">
            <span class="status-chip badge-soft">@Model.ViewModel.ChunkItems.Count khối hiển thị</span>
            <span class="status-chip badge-soft">@Model.ViewModel.Chunks.Count chunks</span>
        </div>
    </div>

    @if (!Model.ViewModel.ChunkItems.Any())
    {
        <div class="alert alert-warning mb-0">
            <strong>Chưa có nội dung.</strong>
            @if (Model.ViewModel.CanReindex)
            {
                <span>Nhấn <strong>Lập chỉ mục lại</strong> hoặc tải lại file này để bắt đầu.</span>
            }
        </div>
    }
    else
    {
        <div class="document-content-list">
            @foreach (var item in Model.ViewModel.ChunkItems)
            {
                var title = item.IsSlide
                    ? $"Slide {item.SlideNumber ?? item.DisplayIndex}"
                    : item.PageNumber.HasValue
                        ? $"Trang {item.PageNumber}"
                        : $"Chunk {item.DisplayIndex}";
                var icon = item.IsSlide ? "presentation" : "file-text";
                var chunkLabel = $"Chunk {item.Chunk.ChunkIndex + 1}";

                <article class="document-content-block @(item.IsSlide ? "is-slide" : "is-page")">
                    <aside class="content-block-marker">
                        <div class="marker-icon"><i data-lucide="@icon" class="icon-sm"></i></div>
                        <div>
                            <div class="marker-title">@title</div>
                            <div class="marker-meta">@chunkLabel</div>
                        </div>
                    </aside>

                    <div class="content-block-body">
                        <div class="content-block-toolbar">
                            <span class="status-chip badge-soft">@item.TokenCount tokens</span>
                        </div>

                        @if (item.ImageUrls.Any())
                        {
                            <div class="reader-image-grid">
                                @foreach (var imageUrl in item.ImageUrls)
                                {
                                    var isBrowserImage = imageUrl.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
                                        || imageUrl.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
                                        || imageUrl.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
                                        || imageUrl.EndsWith(".gif", StringComparison.OrdinalIgnoreCase)
                                        || imageUrl.EndsWith(".webp", StringComparison.OrdinalIgnoreCase);

                                    @if (isBrowserImage)
                                    {
                                        <figure class="reader-image-frame">
                                            <img src="@imageUrl" alt="@title" />
                                        </figure>
                                    }
                                }
                            </div>
                        }

                        <pre class="document-text-block">@item.Content</pre>
                    </div>
                </article>
            }
        </div>
    }
</section>
