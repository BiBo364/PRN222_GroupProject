@page "/Documents/Index"
@model Assignmet1_Presentation.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Thư viện tài liệu";
}

<div class="d-flex flex-column gap-4">

    <!-- ── HERO ──────────────────────────────────────────────────── -->
    <div class="page-hero d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div>
            <div class="hero-badge mb-2">
                <i data-lucide="library" class="icon-sm text-primary"></i> Thư viện tài liệu
            </div>
            <h1 class="page-title mb-1">Thư viện môn học</h1>
            <p class="page-subtitle">Duyệt qua các môn học để xem và tải tài liệu lên hệ thống AI.</p>
        </div>
        @if (Model.ViewModel.CanCreateSubject)
        {
            <div class="d-flex gap-2 flex-shrink-0">
                <a asp-page="/Subjects/Create" class="btn btn-primary">
                    <i data-lucide="plus" class="icon-sm"></i> Môn học mới
                </a>
            </div>
        }
    </div>

    <!-- ── ALERTS ─────────────────────────────────────────────────── -->

    <!-- ── EMPTY STATE ────────────────────────────────────────────── -->
    <div id="subject-empty-state" class="empty-state surface-card" style="display:@(Model.ViewModel.Subjects.Count == 0 ? "block" : "none")">
        <div class="empty-state-icon">
            <i data-lucide="library" style="width:56px;height:56px;color:var(--text-faint)"></i>
        </div>
        <div class="empty-state-title">Chưa có môn học</div>
        <div class="empty-state-desc">Hiện chưa có môn học nào trong hệ thống hoặc bạn chưa được phân công.</div>
        @if (Model.ViewModel.CanCreateSubject)
        {
            <a asp-page="/Subjects/Create" class="btn btn-primary mt-2">
                <i data-lucide="plus" class="icon-sm"></i> Tạo môn học
            </a>
        }
    </div>

    <!-- ── SUBJECT GRID ──────────────────────────────────────────── -->
    <div id="subject-grid" class="row g-4 stagger-children">
        @foreach (var subject in Model.ViewModel.Subjects)
        {
            <div class="col-12 col-md-6 col-xl-4" data-subject-card data-subject-id="@subject.Id" data-subject-code="@subject.Code">
                <a class="surface-card d-flex flex-column h-100 text-decoration-none text-reset" asp-page="/Subjects/Details" asp-route-id="@subject.Id">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <div class="hero-badge mb-2" style="background:var(--bg-alt);border-color:transparent;color:var(--text-sec)">
                                <i data-lucide="book" class="icon-xs"></i> Môn học
                            </div>
                            <h3 class="h5 fw-bold mb-1 subject-code text-gradient">@subject.Code</h3>
                            <div class="subject-name fw-semibold" style="color:var(--text-sec);font-size:.95rem;line-height:1.4">
                                @subject.Name
                            </div>
                        </div>
                        <span class="status-chip success" style="font-size:.7rem">
                            <span class="subject-indexed-count fw-bold me-1">@subject.IndexedDocumentCount</span> đã lập chỉ mục
                        </span>
                    </div>

                    <p class="text-muted subject-description mb-4 flex-grow-1" style="font-size:.85rem;line-height:1.6;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">
                        @(string.IsNullOrEmpty(subject.Description) ? "Không có mô tả" : subject.Description)
                    </p>

                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <span class="status-chip warning" style="font-size:.75rem">
                            <i data-lucide="bookmark" class="icon-xs"></i>
                            <span class="subject-chapter-count ms-1 fw-bold">@subject.ChapterCount</span> chương
                        </span>
                        <span class="status-chip info" style="font-size:.75rem">
                            <i data-lucide="file-text" class="icon-xs"></i>
                            <span class="subject-document-count ms-1 fw-bold">@subject.DocumentCount</span> tài liệu
                        </span>
                    </div>

                    <div class="mt-auto d-flex justify-content-end border-top pt-3" style="border-color:var(--surface-border) !important">
                        <span class="btn btn-sm btn-outline-primary w-100">
                            Xem chi tiết <i data-lucide="arrow-right" class="icon-sm ms-1"></i>
                        </span>
                    </div>
                </a>
            </div>
        }
    </div>

</div>

@section Scripts {
    <script>
        (() => {
            const grid = document.getElementById("subject-grid");
            const emptyState = document.getElementById("subject-empty-state");

            if (!grid) return;

            function cardHtml(subject) {
                const description = subject.description ? subject.description : "Không có mô tả";
                return `
                    <div class="col-12 col-md-6 col-xl-4" data-subject-card data-subject-id="${subject.id}" data-subject-code="${appHubRealtime.escapeHtml(subject.code)}">
                        <a class="surface-card d-flex flex-column h-100 text-decoration-none text-reset" href="/Subjects/Details/${subject.id}">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <div class="hero-badge mb-2" style="background:var(--bg-alt);border-color:transparent;color:var(--text-sec)">
                                        <i data-lucide="book" class="icon-xs"></i> Môn học
                                    </div>
                                    <h3 class="h5 fw-bold mb-1 subject-code text-gradient">${appHubRealtime.escapeHtml(subject.code)}</h3>
                                    <div class="subject-name fw-semibold" style="color:var(--text-sec);font-size:.95rem;line-height:1.4">
                                        ${appHubRealtime.escapeHtml(subject.name)}
                                    </div>
                                </div>
                                <span class="status-chip success" style="font-size:.7rem">
                                    <span class="subject-indexed-count fw-bold me-1">${subject.indexedDocumentCount ?? 0}</span> đã lập chỉ mục
                                </span>
                            </div>
                            <p class="text-muted subject-description mb-4 flex-grow-1" style="font-size:.85rem;line-height:1.6;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">
                                ${appHubRealtime.escapeHtml(description)}
                            </p>
                            <div class="d-flex flex-wrap gap-2 mb-4">
                                <span class="status-chip warning" style="font-size:.75rem">
                                    <i data-lucide="bookmark" class="icon-xs"></i>
                                    <span class="subject-chapter-count ms-1 fw-bold">${subject.chapterCount ?? 0}</span> chương
                                </span>
                                <span class="status-chip info" style="font-size:.75rem">
                                    <i data-lucide="file-text" class="icon-xs"></i>
                                    <span class="subject-document-count ms-1 fw-bold">${subject.documentCount ?? 0}</span> tài liệu
                                </span>
                            </div>
                            <div class="mt-auto d-flex justify-content-end border-top pt-3" style="border-color:var(--surface-border) !important">
                                <span class="btn btn-sm btn-outline-primary w-100">
                                    Xem chi tiết <i data-lucide="arrow-right" class="icon-sm ms-1"></i>
                                </span>
                            </div>
                        </a>
                    </div>`;
            }

            function updateEmptyState() {
                const cards = grid.querySelectorAll("[data-subject-card]");
                if (emptyState) {
                    emptyState.style.display = cards.length === 0 ? "block" : "none";
                }
            }

            function sortCards() {
                const cards = Array.from(grid.querySelectorAll("[data-subject-card]"));
                cards.sort((a, b) => (a.getAttribute("data-subject-code") || "").localeCompare(b.getAttribute("data-subject-code") || ""));
                cards.forEach(card => grid.appendChild(card));
            }

            function upsertSubject(subject) {
                const existing = grid.querySelector(`[data-subject-card][data-subject-id="${subject.id}"]`);
                if (existing) {
                    existing.setAttribute("data-subject-code", subject.code || "");
                    existing.querySelector(".subject-code").textContent = subject.code || "";
                    existing.querySelector(".subject-name").textContent = subject.name || "";
                    existing.querySelector(".subject-description").textContent = subject.description || "Không có mô tả";
                    existing.querySelector(".subject-indexed-count").textContent = String(subject.indexedDocumentCount ?? 0);
                    existing.querySelector(".subject-chapter-count").textContent = String(subject.chapterCount ?? 0);
                    existing.querySelector(".subject-document-count").textContent = String(subject.documentCount ?? 0);
                } else {
                    grid.insertAdjacentHTML("beforeend", cardHtml(subject));
                    lucide.createIcons();
                }

                sortCards();
                updateEmptyState();
            }

            function removeSubject(id) {
                const card = grid.querySelector(`[data-subject-card][data-subject-id="${id}"]`);
                if (card) card.remove();
                updateEmptyState();
            }

            updateEmptyState();

            window.appHubRealtime.createConnection({
                CourseCreated: upsertSubject,
                CourseUpdated: upsertSubject,
                CourseDeleted: removeSubject
            });
        })();
    </script>
}
