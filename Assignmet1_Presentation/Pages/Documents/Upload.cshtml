@page "/Documents/Upload"
@model Assignmet1_Presentation.Pages.Documents.UploadModel
@{
    ViewData["Title"] = "Upload document";
}

<section class="page-hero mb-4">
    <div class="hero-badge mb-3">Upload</div>
    <h1 class="page-title mb-2">Upload document</h1>
    @if (Model.ViewModel.Subject is not null)
    {
        <p class="page-subtitle">Subject: <strong>@Model.ViewModel.Subject.Code</strong> - @Model.ViewModel.Subject.Name</p>
    }
</section>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div id="uploadError" class="alert alert-danger d-none" role="alert"></div>
<div id="uploadSuccess" class="alert alert-success d-none" role="alert"></div>

<div class="surface-card">
    <form id="uploadForm" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input asp-for="ViewModel.SubjectId" type="hidden" />

        @if (Model.ViewModel.Subject is not null)
        {
            <div class="alert alert-info">
                Uploading to <strong>@Model.ViewModel.Subject.Code</strong> - @Model.ViewModel.Subject.Name.
            </div>
        }

        <div class="mb-3">
            <label asp-for="ViewModel.File" class="form-label"></label>
            <input asp-for="ViewModel.File" class="form-control" accept=".pdf,.docx,.pptx" />
            <div class="form-text">Supported: PDF, DOCX, PPTX (lecture slides).</div>
            <span asp-validation-for="ViewModel.File" class="text-danger"></span>
        </div>

        @if (Model.ViewModel.ChapterOptions.Any())
        {
            <div class="mb-3">
                <label asp-for="ViewModel.ChapterId" class="form-label"></label>
                <select asp-for="ViewModel.ChapterId" asp-items="Model.ViewModel.ChapterOptions" class="form-select">
                    <option value="">-- Select chapter --</option>
                </select>
                <span asp-validation-for="ViewModel.ChapterId" class="text-danger"></span>
            </div>
        }

        <div id="uploadProgressPanel" class="upload-progress-panel d-none mb-4" aria-live="polite">
            <div class="d-flex justify-content-between align-items-center gap-3 mb-2">
                <div>
                    <div class="small fw-semibold text-uppercase">Upload progress</div>
                    <div id="uploadStatusText" class="page-subtitle small mb-0">Preparing your document...</div>
                </div>
                <div id="uploadPercentText" class="upload-progress-value">0%</div>
            </div>

            <div class="progress upload-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                <div id="uploadProgressBar" class="progress-bar progress-bar-striped progress-bar-animated upload-progress-bar" style="width: 0%;"></div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button id="uploadSubmitButton" type="submit" class="btn btn-primary">Upload &amp; index</button>
            <a asp-page="/Documents/Index" class="btn btn-outline-light">Back to subjects</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const form = document.getElementById("uploadForm");
            const submitButton = document.getElementById("uploadSubmitButton");
            const progressPanel = document.getElementById("uploadProgressPanel");
            const progressBar = document.getElementById("uploadProgressBar");
            const progressTrack = progressPanel?.querySelector(".progress");
            const percentText = document.getElementById("uploadPercentText");
            const statusText = document.getElementById("uploadStatusText");
            const errorBox = document.getElementById("uploadError");
            const successBox = document.getElementById("uploadSuccess");
            const fileInput = document.getElementById("ViewModel_File");

            if (!form || !submitButton || !progressPanel || !progressBar || !percentText || !statusText || !fileInput) {
                return;
            }

            let isPending = false;
            let processingTimer = null;
            let currentProgress = 0;

            const setError = (message) => {
                if (!errorBox) {
                    return;
                }

                if (!message) {
                    errorBox.textContent = "";
                    errorBox.classList.add("d-none");
                    return;
                }

                errorBox.textContent = message;
                errorBox.classList.remove("d-none");
            };

            const setSuccess = (message) => {
                if (!successBox) {
                    return;
                }

                if (!message) {
                    successBox.textContent = "";
                    successBox.classList.add("d-none");
                    return;
                }

                successBox.textContent = message;
                successBox.classList.remove("d-none");
            };

            const setProgress = (value, status) => {
                currentProgress = Math.max(currentProgress, Math.min(100, Math.round(value)));
                progressPanel.classList.remove("d-none");
                progressBar.style.width = `${currentProgress}%`;
                progressBar.setAttribute("aria-valuenow", currentProgress.toString());
                percentText.textContent = `${currentProgress}%`;

                if (progressTrack) {
                    progressTrack.setAttribute("aria-valuenow", currentProgress.toString());
                }

                if (status) {
                    statusText.textContent = status;
                }
            };

            const startProcessingAnimation = () => {
                window.clearInterval(processingTimer);
                processingTimer = window.setInterval(() => {
                    if (currentProgress >= 96) {
                        window.clearInterval(processingTimer);
                        processingTimer = null;
                        return;
                    }

                    setProgress(currentProgress + 1, "File uploaded. Extracting text and indexing the material...");
                }, 300);
            };

            const stopProcessingAnimation = () => {
                window.clearInterval(processingTimer);
                processingTimer = null;
            };

            form.addEventListener("submit", (event) => {
                if (isPending) {
                    event.preventDefault();
                    return;
                }

                event.preventDefault();

                const file = fileInput.files && fileInput.files.length > 0
                    ? fileInput.files[0]
                    : null;

                if (!file) {
                    setError("Please select a file before uploading.");
                    fileInput.focus();
                    return;
                }

                setError("");
                setSuccess("");
                currentProgress = 0;
                setProgress(1, "Starting upload...");
                isPending = true;
                submitButton.disabled = true;

                const xhr = new XMLHttpRequest();
                xhr.open("POST", form.action, true);
                xhr.setRequestHeader("X-Requested-With", "XMLHttpRequest");
                xhr.setRequestHeader("Accept", "application/json");

                xhr.upload.addEventListener("progress", (progressEvent) => {
                    if (!progressEvent.lengthComputable) {
                        setProgress(18, "Uploading document to the server...");
                        return;
                    }

                    const uploadPercent = Math.round((progressEvent.loaded / progressEvent.total) * 72);
                    setProgress(Math.max(uploadPercent, 5), "Uploading document to the server...");
                });

                xhr.upload.addEventListener("load", () => {
                    setProgress(76, "Upload completed. Waiting for indexing...");
                    startProcessingAnimation();
                });

                xhr.onreadystatechange = () => {
                    if (xhr.readyState !== XMLHttpRequest.DONE) {
                        return;
                    }

                    stopProcessingAnimation();
                    isPending = false;
                    submitButton.disabled = false;

                    let payload = {};
                    try {
                        payload = xhr.responseText ? JSON.parse(xhr.responseText) : {};
                    } catch {
                        payload = {};
                    }

                    if (xhr.status >= 200 && xhr.status < 300) {
                        setProgress(100, "Upload and indexing completed successfully.");
                        setSuccess(payload.message || "Document uploaded successfully.");

                        const redirectUrl = payload.redirectUrl;
                        if (redirectUrl) {
                            window.setTimeout(() => {
                                window.location.href = redirectUrl;
                            }, 900);
                        }

                        return;
                    }

                    setProgress(Math.max(currentProgress, 1), "Upload failed.");
                    progressBar.classList.remove("progress-bar-animated");
                    progressBar.classList.add("bg-danger");
                    setError(payload.error || "Upload failed. Please try again.");
                };

                xhr.onerror = () => {
                    stopProcessingAnimation();
                    isPending = false;
                    submitButton.disabled = false;
                    setProgress(Math.max(currentProgress, 1), "Upload failed.");
                    progressBar.classList.remove("progress-bar-animated");
                    progressBar.classList.add("bg-danger");
                    setError("Unable to reach the server during upload.");
                };

                progressBar.classList.remove("bg-danger");
                progressBar.classList.add("progress-bar-animated");
                xhr.send(new FormData(form));
            });
        })();
    </script>
}
