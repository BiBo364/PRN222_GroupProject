@page "/Documents/Upload"
@model Assignmet1_Presentation.Pages.Documents.UploadModel
@{
    ViewData["Title"] = "Tải tài liệu lên";
}

<div class="d-flex flex-column gap-4">
    <!-- ── HERO ──────────────────────────────────────────────────── -->
    <div class="page-hero d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div>
            <div class="hero-badge mb-2">
                <i data-lucide="upload" class="icon-sm text-primary"></i> Tải lên
            </div>
            <h1 class="page-title mb-1">Tải tài liệu mới lên</h1>
            @if (Model.ViewModel.Subject is not null)
            {
                <p class="page-subtitle">Môn học: <strong class="text-primary">@Model.ViewModel.Subject.Code</strong> - @Model.ViewModel.Subject.Name</p>
            }
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
            <a asp-page="/Documents/Index" class="btn btn-outline-secondary">
                <i data-lucide="arrow-left" class="icon-sm"></i> Quay lại Thư viện
            </a>
        </div>
    </div>

    <!-- ── ALERTS ─────────────────────────────────────────────────── -->

    <div id="uploadError" class="alert alert-danger d-none mb-0" role="alert">
        <i data-lucide="alert-triangle" class="alert-icon"></i> <span class="error-msg"></span>
    </div>
    <div id="uploadSuccess" class="alert alert-success d-none mb-0" role="alert">
        <i data-lucide="check-circle-2" class="alert-icon"></i> <span class="success-msg"></span>
    </div>

    <!-- ── UPLOAD FORM ────────────────────────────────────────────── -->
    <div class="surface-card p-4 mx-auto" style="max-width: 600px; width: 100%;">
        <form id="uploadForm" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:.85rem"></div>

            <input asp-for="ViewModel.SubjectId" type="hidden" />

            @if (Model.ViewModel.Subject is not null)
            {
                <div class="alert alert-info py-2 px-3 mb-4 d-flex align-items-center gap-2" style="font-size:.85rem">
                    <i data-lucide="info" class="icon-sm flex-shrink-0"></i>
                    <div>
                        Đang tải tài liệu lên môn học <strong>@Model.ViewModel.Subject.Code</strong>.
                    </div>
                </div>
            }

            <div class="mb-4">
                <label asp-for="ViewModel.File" class="form-label fw-semibold">Tài liệu</label>
                <div class="upload-zone position-relative border rounded p-4 text-center mb-1" style="background:var(--bg-alt);border-style:dashed!important;border-color:var(--surface-border)!important">
                    <i data-lucide="file-up" style="width:48px;height:48px;color:var(--text-faint)" class="mb-3"></i>
                    <h6 class="mb-1 fw-bold" style="color:var(--text)">Chon hoac keo tha file</h6>
                    <p class="small text-muted mb-3">Ho tro: PDF, DOCX, PPTX</p>
                    <input asp-for="ViewModel.File" class="form-control form-control-sm mx-auto" style="max-width: 300px;" accept=".pdf,.docx,.pptx" />
                </div>
                <span asp-validation-for="ViewModel.File" class="text-danger small"></span>
            </div>

            @if (Model.ViewModel.ChapterOptions.Any())
            {
                <div class="mb-4">
                    <label asp-for="ViewModel.ChapterId" class="form-label fw-semibold">Chương (tùy chọn)</label>
                    <select asp-for="ViewModel.ChapterId" asp-items="Model.ViewModel.ChapterOptions" class="form-select form-select-lg">
                        <option value="">-- Chọn chương --</option>
                    </select>
                    <span asp-validation-for="ViewModel.ChapterId" class="text-danger small"></span>
                </div>
            }

            <div id="uploadProgressPanel" class="upload-progress-panel d-none mb-4 p-3 rounded" style="background:var(--bg-alt);border:1px solid var(--surface-border)" aria-live="polite">
                <div class="d-flex justify-content-between align-items-center gap-3 mb-2">
                    <div>
                        <div class="small fw-semibold text-uppercase d-flex align-items-center" style="color:var(--primary)">
                            <i data-lucide="loader-2" class="icon-sm me-2 spin"></i> Tiến trình tải lên
                        </div>
                        <div id="uploadStatusText" class="page-subtitle small mb-0 mt-1">Đang chuẩn bị tài liệu...</div>
                    </div>
                    <div id="uploadPercentText" class="fs-4 text-primary fw-bold" style="font-feature-settings:'tnum'">0%</div>
                </div>

                <div class="progress upload-progress-track mt-3" style="height:6px;border-radius:100px;background:var(--surface-border)" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
                    <div id="uploadProgressBar" class="progress-bar progress-bar-striped progress-bar-animated upload-progress-bar bg-primary" style="border-radius:100px;width:0%"></div>
                </div>
            </div>

            <div class="d-grid gap-2 pt-2 border-top" style="border-color:var(--surface-border)!important">
                <button id="uploadSubmitButton" type="submit" class="btn btn-primary btn-lg">
                    <i data-lucide="upload-cloud" class="icon-sm me-2"></i> Tải lên và lập chỉ mục
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const form = document.getElementById("uploadForm");
            const submitButton = document.getElementById("uploadSubmitButton");
            const progressPanel = document.getElementById("uploadProgressPanel");
            const progressBar = document.getElementById("uploadProgressBar");
            const progressTrack = progressPanel?.querySelector(".progress");
            const percentText = document.getElementById("uploadPercentText");
            const statusText = document.getElementById("uploadStatusText");
            const errorBox = document.getElementById("uploadError");
            const successBox = document.getElementById("uploadSuccess");
            const fileInput = document.getElementById("ViewModel_File");

            if (!form || !submitButton || !progressPanel || !progressBar || !percentText || !statusText || !fileInput) {
                return;
            }

            let isPending = false;
            let processingTimer = null;
            let currentProgress = 0;

            const setError = (message) => {
                if (!errorBox) return;
                if (!message) {
                    errorBox.classList.add("d-none");
                    return;
                }
                errorBox.querySelector('.error-msg').textContent = message;
                errorBox.classList.remove("d-none");
            };

            const setSuccess = (message) => {
                if (!successBox) return;
                if (!message) {
                    successBox.classList.add("d-none");
                    return;
                }
                successBox.querySelector('.success-msg').textContent = message;
                successBox.classList.remove("d-none");
            };

            const setProgress = (value, status) => {
                currentProgress = Math.max(currentProgress, Math.min(100, Math.round(value)));
                progressPanel.classList.remove("d-none");
                progressBar.style.width = `${currentProgress}%`;
                progressBar.setAttribute("aria-valuenow", currentProgress.toString());
                percentText.textContent = `${currentProgress}%`;

                if (progressTrack) {
                    progressTrack.setAttribute("aria-valuenow", currentProgress.toString());
                }

                if (status) {
                    statusText.textContent = status;
                }
            };

            const startProcessingAnimation = () => {
                window.clearInterval(processingTimer);
                processingTimer = window.setInterval(() => {
                    if (currentProgress >= 96) {
                        window.clearInterval(processingTimer);
                        processingTimer = null;
                        return;
                    }
                    setProgress(currentProgress + 1, "Đã tải xong tệp. Đang trích xuất nội dung và lập chỉ mục...");
                }, 300);
            };

            const stopProcessingAnimation = () => {
                window.clearInterval(processingTimer);
                processingTimer = null;
            };

            form.addEventListener("submit", (event) => {
                if (isPending) {
                    event.preventDefault();
                    return;
                }
                event.preventDefault();

                const file = fileInput.files && fileInput.files.length > 0 ? fileInput.files[0] : null;

                if (!file) {
                    setError("Vui lòng chọn tài liệu trước khi tải lên.");
                    fileInput.focus();
                    return;
                }

                setError("");
                setSuccess("");
                currentProgress = 0;
                setProgress(1, "Đang bắt đầu tải lên...");
                isPending = true;
                submitButton.disabled = true;

                const xhr = new XMLHttpRequest();
                xhr.open("POST", form.action, true);
                xhr.setRequestHeader("X-Requested-With", "XMLHttpRequest");
                xhr.setRequestHeader("Accept", "application/json");

                xhr.upload.addEventListener("progress", (progressEvent) => {
                    if (!progressEvent.lengthComputable) {
                        setProgress(18, "Đang tải tài liệu lên máy chủ...");
                        return;
                    }
                    const uploadPercent = Math.round((progressEvent.loaded / progressEvent.total) * 72);
                    setProgress(Math.max(uploadPercent, 5), "Đang tải tài liệu lên máy chủ...");
                });

                xhr.upload.addEventListener("load", () => {
                    setProgress(76, "Đã tải lên hoàn tất. Đang chờ lập chỉ mục...");
                    startProcessingAnimation();
                });

                xhr.onreadystatechange = () => {
                    if (xhr.readyState !== XMLHttpRequest.DONE) return;

                    stopProcessingAnimation();
                    isPending = false;
                    submitButton.disabled = false;

                    let payload = {};
                    try {
                        payload = xhr.responseText ? JSON.parse(xhr.responseText) : {};
                    } catch {
                        payload = {};
                    }

                    if (xhr.status >= 200 && xhr.status < 300) {
                        setProgress(100, "Tải lên và lập chỉ mục thành công.");

                        const redirectUrl = payload.redirectUrl;
                        if (redirectUrl) {
                            window.setTimeout(() => {
                                window.location.href = redirectUrl;
                            }, 900);
                            return;
                        }

                        setSuccess(payload.message || "Đã tải tài liệu lên thành công.");
                        return;
                    }

                    // Khi có lỗi xảy ra (như trùng lặp tài liệu)
                    if (progressPanel) {
                        progressPanel.classList.add("d-none"); // Ẩn panel tiến trình để tránh cảm giác bị treo
                    }
                    setError(payload.error || "Tải tài liệu lên thất bại. Vui lòng thử lại.");

                    // Hiển thị thông báo dạng Alert đẹp đẽ ngay trên giao diện
                    Swal.fire({
                        title: "Tải lên thất bại",
                        text: payload.error || "Tài liệu này đã tồn tại hoặc có lỗi xảy ra.",
                        icon: "error",
                        confirmButtonColor: "#dc2626", // Màu đỏ cảnh báo
                        confirmButtonText: "Đóng"
                    });
                };

                xhr.onerror = () => {
                    stopProcessingAnimation();
                    isPending = false;
                    submitButton.disabled = false;
                    
                    if (progressPanel) {
                        progressPanel.classList.add("d-none");
                    }
                    setError("Không thể kết nối với máy chủ trong quá trình tải lên.");

                    Swal.fire({
                        title: "Lỗi kết nối",
                        text: "Không thể kết nối với máy chủ trong quá trình tải lên.",
                        icon: "error",
                        confirmButtonColor: "#dc2626",
                        confirmButtonText: "Đóng"
                    });
                };

                progressBar.classList.remove("bg-danger");
                progressBar.classList.add("progress-bar-animated");
                xhr.send(new FormData(form));
            });
        })();
    </script>
}
