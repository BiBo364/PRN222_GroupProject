@page "/Error"
@model Assignmet1_Presentation.Pages.ErrorModel
@{
    ViewData["Title"] = "Lỗi";
}

<div class="page-hero">
    <div class="hero-badge mb-3">Có lỗi xảy ra</div>
    <h1 class="page-title text-danger">Lỗi hệ thống</h1>
    <p class="page-subtitle">Huỳ xảy ra lỗi trong quá trình xử lý yêu cầu của bạn.</p>

    @if (Model.ErrorViewModel.ShowRequestId)
    {
        <div class="mini-panel mt-4">
            <div class="stat-label">Mã yêu cầu</div>
            <div class="fw-semibold">@Model.ErrorViewModel.RequestId</div>
        </div>
    }
</div>
