@page
@model Assignmet1_Presentation.Pages.Home.IndexModel
@{
    ViewData["Title"] = "Trang chủ";
    var userId = Model.UserId;
    var displayName = Model.DisplayName;
    var roleId = HttpContext.Session.GetInt32("RoleId");
}

<section class="page-hero home-hero mb-4">
    <div class="home-hero-grid">
        <div class="home-hero-copy">
            <div class="hero-badge mb-4">
                <i data-lucide="sparkles" class="icon-sm"></i>
                Không gian học tập thông minh
            </div>

            <h1 class="home-hero-title">
                Biến tài liệu thành <span>trải nghiệm học tập chủ động.</span>
            </h1>

            <p class="home-hero-subtitle">
                Quản lý học liệu, hỏi đáp có nguồn tham khảo và dùng AI để tạo câu hỏi,
                thẻ ghi nhớ cùng trò chơi ôn tập trong một quy trình thống nhất.
            </p>

            <div class="home-hero-actions">
                @if (userId is not null)
                {
                    @if (roleId == 1)
                    {
                        <a class="btn btn-primary btn-lg" asp-page="/Subjects/Manage">
                            <i data-lucide="layout-dashboard" class="icon-sm"></i>
                            Mở trang quản trị
                        </a>
                        <a class="btn btn-outline-primary btn-lg" asp-page="/Admin/Index">
                            <i data-lucide="users" class="icon-sm"></i>
                            Quản lý người dùng
                        </a>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-lg" asp-page="/Learning/Index">
                            <i data-lucide="brain-circuit" class="icon-sm"></i>
                            Mở trung tâm ôn tập
                        </a>
                        <a class="btn btn-outline-primary btn-lg" asp-page="/Documents/Index">
                            <i data-lucide="library" class="icon-sm"></i>
                            Khám phá thư viện
                        </a>
                    }
                }
                else
                {
                    <a class="btn btn-primary btn-lg" asp-page="/Account/Login">
                        <i data-lucide="log-in" class="icon-sm"></i>
                        Bắt đầu học tập
                    </a>
                    <a class="btn btn-outline-primary btn-lg" asp-page="/Home/Privacy">
                        <i data-lucide="shield-check" class="icon-sm"></i>
                        Tìm hiểu nền tảng
                    </a>
                }
            </div>

            <div class="home-trust-row" aria-label="Điểm nổi bật của nền tảng">
                <span><i data-lucide="check-circle-2"></i> Câu trả lời bám sát tài liệu</span>
                <span><i data-lucide="check-circle-2"></i> Phân quyền theo vai trò</span>
                <span><i data-lucide="check-circle-2"></i> Giao diện thích ứng mọi thiết bị</span>
            </div>
        </div>

        <div class="home-workspace-preview" aria-label="Mô phỏng không gian làm việc">
            <div class="home-preview-bar">
                <div class="home-preview-dots" aria-hidden="true">
                    <span></span><span></span><span></span>
                </div>
                <div class="home-preview-status">
                    @(userId is not null ? "Phiên học đã sẵn sàng" : "Hệ thống đang hoạt động")
                </div>
            </div>

            <div class="home-preview-main">
                <div class="home-preview-sidebar" aria-hidden="true">
                    <span><i data-lucide="home"></i></span>
                    <span><i data-lucide="library"></i></span>
                    <span><i data-lucide="message-square"></i></span>
                    <span><i data-lucide="brain-circuit"></i></span>
                </div>

                <div class="home-preview-content">
                    <div class="home-preview-welcome">
                        <small>@(userId is not null ? "Chào mừng bạn trở lại" : "Chào mừng đến RAG Edu Hub")</small>
                        <strong>@(userId is not null ? displayName : "Học đúng trọng tâm, ghi nhớ lâu hơn")</strong>
                    </div>

                    <div class="home-preview-grid">
                        <div class="home-preview-card">
                            <i data-lucide="files"></i>
                            <strong>Thư viện học liệu</strong>
                        </div>
                        <div class="home-preview-card">
                            <i data-lucide="bot"></i>
                            <strong>Hỏi đáp cùng AI</strong>
                        </div>
                        <div class="home-preview-card">
                            <i data-lucide="clipboard-check"></i>
                            <strong>Bài kiểm tra ôn tập</strong>
                        </div>
                        <div class="home-preview-card">
                            <i data-lucide="panels-top-left"></i>
                            <strong>Thẻ ghi nhớ và trò chơi</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-capabilities" aria-label="Các năng lực chính">
    <article class="home-capability-card">
        <div class="home-capability-icon"><i data-lucide="scan-text"></i></div>
        <h2>Học liệu có cấu trúc</h2>
        <p>
            Tài liệu được tổ chức theo môn học và chương, giúp giảng viên quản lý thuận tiện
            và sinh viên tìm đúng nội dung cần học.
        </p>
    </article>

    <article class="home-capability-card">
        <div class="home-capability-icon"><i data-lucide="message-circle-more"></i></div>
        <h2>Hỏi đáp có căn cứ</h2>
        <p>
            Câu trả lời được xây dựng từ nội dung đã lập chỉ mục, đi kèm nguồn tham khảo
            để người học dễ dàng kiểm chứng.
        </p>
    </article>

    <article class="home-capability-card">
        <div class="home-capability-icon"><i data-lucide="wand-sparkles"></i></div>
        <h2>Ôn tập bằng AI</h2>
        <p>
            Giảng viên tạo ngân hàng câu hỏi từ tài liệu, sau đó tái sử dụng để phối hợp
            bài kiểm tra, thẻ ghi nhớ và trò chơi học tập.
        </p>
    </article>
</section>
