@page
@model Assignmet1_Presentation.Pages.Home.IndexModel
@{
    ViewData["Title"] = "Trang chủ";
    var userId = Model.UserId;
    var displayName = Model.DisplayName;
}

<section class="page-hero mb-4">
    <div class="hero-badge mb-3">Nền tảng học tập trực tuyến</div>
    <div class="hero-grid align-items-center">
        <div>
            <h1 class="page-title">Không gian học tập tích hợp tài liệu, Chat AI và quản lý học phí.</h1>
            <p class="page-subtitle fs-5">
                Duyệt tài liệu, đặt câu hỏi với câu trả lời có trích dẫn, và quản lý thanh toán trong một ứng dụng.
            </p>
            <div class="d-flex flex-wrap gap-2 mt-4">
                @if (userId is not null)
                {
                    <a class="btn btn-primary" asp-page="/Documents/Index">Mở thư viện</a>
                    <a class="btn btn-outline-light" asp-page="/Chat/Index">Bắt đầu chat</a>
                    <a class="btn btn-outline-secondary" asp-page="/Subscription/Index">Gói học</a>
                }
                else
                {
                    <a class="btn btn-primary" asp-page="/Account/Login">Đăng nhập</a>
                    <a class="btn btn-outline-light" asp-page="/Home/Privacy">Tìm hiểu thêm</a>
                }
            </div>
        </div>
        <div class="surface-card">
            <div class="stat-label mb-2">Trạng thái</div>
            <div class="stat-value mb-2">@((userId is not null) ? "Sẵn sàng" : "Vui lòng đăng nhập")</div>
            <p class="page-subtitle mb-3">
                @if (userId is not null)
                {
                    <span>Đăng nhập với tên <strong>@displayName</strong>. Tài liệu, phiên chat và thông tin học phí sẵn sàng.</span>
                }
                else
                {
                    <span>Hãy đăng nhập để truy cập tài liệu, chat AI và các tính năng khác.</span>
                }
            </p>
            <div class="d-grid gap-2">
                <div class="mini-panel">
                    <div class="stat-label">Giao diện</div>
                    <div class="fw-semibold">Kiến trúc MVC 3 lớp</div>
                </div>
                <div class="mini-panel">
                    <div class="stat-label">Backend</div>
                    <div class="fw-semibold">Phân tách Service + Repository</div>
                </div>
            </div>
        </div>
    </div>
</section>
