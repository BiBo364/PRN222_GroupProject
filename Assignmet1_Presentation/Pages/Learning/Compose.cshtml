@page
@model Assignmet1_Presentation.Pages.Learning.ComposeModel
@{
    ViewData["Title"] = "Tổng hợp bộ ôn tập";
}

@if (Model.Options is not null)
{
    <div class="learning-page-heading">
        <div>
            <a class="learning-back-link" asp-page="/Learning/Index">
                <i data-lucide="arrow-left" class="icon-sm"></i>
                Trung tâm ôn tập
            </a>
            <span class="eyebrow">AI Composer</span>
            <h1>Biến ngân hàng đề thành trải nghiệm ôn tập</h1>
            <p>
                AI chọn, phối hợp và xáo trộn câu hỏi của
                <strong>@Model.Options.Subject.Code - @Model.Options.Subject.Name</strong>
                thành một hoạt động hoàn chỉnh.
            </p>
        </div>
        <span class="learning-icon learning-icon-xl learning-icon-violet">
            <i data-lucide="layers-3"></i>
        </span>
    </div>

    <div class="learning-stat-grid learning-stat-grid-compact">
        <article class="learning-stat surface-card">
            <span class="learning-icon"><i data-lucide="database"></i></span>
            <div>
                <strong>@Model.Options.AvailableQuestionCount</strong>
                <span>Câu hỏi có thể tái sử dụng</span>
            </div>
        </article>
        <article class="learning-stat surface-card">
            <span class="learning-icon learning-icon-violet"><i data-lucide="gauge"></i></span>
            <div>
                <strong>@(Model.Options.CountByDifficulty.TryGetValue(LearningDifficultyLevels.Hard, out var hardCount) ? hardCount : 0)</strong>
                <span>Câu hỏi nâng cao</span>
            </div>
        </article>
        <article class="learning-stat surface-card">
            <span class="learning-icon learning-icon-amber"><i data-lucide="list-checks"></i></span>
            <div>
                <strong>@(Model.Options.CountByQuestionType.TryGetValue(LearningQuestionTypes.MultipleChoice, out var mcqCount) ? mcqCount : 0)</strong>
                <span>Câu nhiều lựa chọn</span>
            </div>
        </article>
    </div>

    <form method="post" class="surface-card learning-composer" id="composeLearningSetForm">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <section class="learning-form-section border-0 p-0">
            <div class="form-section-title">
                <span>01</span>
                <div>
                    <h2>Chọn trải nghiệm học tập</h2>
                    <p>Mỗi chế độ sử dụng cùng một ngân hàng câu hỏi nhưng có cách tương tác khác nhau.</p>
                </div>
            </div>

            <div class="activity-picker">
                <label class="activity-option">
                    <input type="radio" name="Input.ActivityType" value="@LearningActivityTypes.Quiz"
                           checked="@(Model.Input.ActivityType == LearningActivityTypes.Quiz)" />
                    <span class="learning-icon"><i data-lucide="list-checks"></i></span>
                    <span><strong>Quiz</strong><small>Làm bài, nộp đáp án và nhận kết quả chi tiết.</small></span>
                    <i data-lucide="check-circle-2" class="activity-check"></i>
                </label>
                <label class="activity-option">
                    <input type="radio" name="Input.ActivityType" value="@LearningActivityTypes.Flashcard"
                           checked="@(Model.Input.ActivityType == LearningActivityTypes.Flashcard)" />
                    <span class="learning-icon learning-icon-violet"><i data-lucide="copy"></i></span>
                    <span><strong>Thẻ ghi nhớ</strong><small>Lật thẻ để luyện khả năng gợi nhớ chủ động.</small></span>
                    <i data-lucide="check-circle-2" class="activity-check"></i>
                </label>
                <label class="activity-option">
                    <input type="radio" name="Input.ActivityType" value="@LearningActivityTypes.Matching"
                           checked="@(Model.Input.ActivityType == LearningActivityTypes.Matching)" />
                    <span class="learning-icon learning-icon-amber"><i data-lucide="workflow"></i></span>
                    <span><strong>Ghép cặp</strong><small>Ghép câu hỏi với đáp án tương ứng.</small></span>
                    <i data-lucide="check-circle-2" class="activity-check"></i>
                </label>
                <label class="activity-option">
                    <input type="radio" name="Input.ActivityType" value="@LearningActivityTypes.SpeedChallenge"
                           checked="@(Model.Input.ActivityType == LearningActivityTypes.SpeedChallenge)" />
                    <span class="learning-icon learning-icon-rose"><i data-lucide="timer"></i></span>
                    <span><strong>Thử thách tốc độ</strong><small>Trả lời nhanh câu trắc nghiệm trong thời gian giới hạn.</small></span>
                    <i data-lucide="check-circle-2" class="activity-check"></i>
                </label>
            </div>
        </section>

        <div class="composer-divider"></div>

        <section class="learning-form-section border-0 p-0">
            <div class="form-section-title">
                <span>02</span>
                <div>
                    <h2>Giao mục tiêu cho AI</h2>
                    <p>AI sẽ chọn câu hỏi phù hợp, đặt tiêu đề, viết mô tả và hướng dẫn.</p>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-field">
                    <label asp-for="Input.QuestionCount">Số nội dung trong bộ</label>
                    <input asp-for="Input.QuestionCount"
                           class="form-control"
                           type="number"
                           min="1"
                           max="@Math.Min(50, Model.Options.AvailableQuestionCount)" />
                    <span asp-validation-for="Input.QuestionCount" class="text-danger"></span>
                </div>
                <div class="form-field">
                    <label asp-for="Input.Difficulty">Mức độ</label>
                    <select asp-for="Input.Difficulty" class="form-select">
                        <option value="@LearningDifficultyLevels.Mixed">Phối hợp nhiều mức độ</option>
                        <option value="@LearningDifficultyLevels.Easy">Cơ bản</option>
                        <option value="@LearningDifficultyLevels.Medium">Trung bình</option>
                        <option value="@LearningDifficultyLevels.Hard">Nâng cao</option>
                    </select>
                </div>
            </div>
            <div class="form-field mt-4">
                <label asp-for="Input.Focus">Chủ đề hoặc mục tiêu mong muốn</label>
                <textarea asp-for="Input.Focus"
                          class="form-control"
                          rows="4"
                          placeholder="Ví dụ: tạo bài ôn tập cuối chương, cân bằng lý thuyết và tình huống thực tế."></textarea>
                <span asp-validation-for="Input.Focus" class="text-danger"></span>
            </div>
            <label class="publish-option mt-4">
                <input asp-for="Input.PublishImmediately" />
                <span class="publish-option-toggle"></span>
                <span>
                    <strong>Phát hành ngay cho sinh viên</strong>
                    <small>Tắt lựa chọn này nếu bạn muốn rà soát nội dung trước.</small>
                </span>
            </label>
        </section>

        <div class="composer-actions">
            <a class="btn btn-outline-secondary" asp-page="/Learning/Index">Hủy</a>
            <button type="submit"
                    class="btn btn-primary btn-lg"
                    @(Model.Options.AvailableQuestionCount == 0 ? "disabled" : null)>
                <i data-lucide="sparkles" class="icon-sm"></i>
                Để AI tổng hợp
            </button>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('composeLearningSetForm')?.addEventListener('submit', event => {
            const submitButton = event.currentTarget.querySelector('button[type="submit"]');
            if (!submitButton || !event.currentTarget.checkValidity()) return;
            submitButton.disabled = true;
            submitButton.innerHTML = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span> AI đang tổng hợp...';
        });
    </script>
}
