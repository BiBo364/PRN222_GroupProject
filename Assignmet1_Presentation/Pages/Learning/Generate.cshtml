@page
@model Assignmet1_Presentation.Pages.Learning.GenerateModel
@{
    ViewData["Title"] = "Tạo câu hỏi bằng AI";
}

@if (Model.Options is not null)
{
    <div class="learning-page-heading">
        <div>
            <a class="learning-back-link" asp-page="/Learning/Index">
                <i data-lucide="arrow-left" class="icon-sm"></i>
                Trung tâm ôn tập
            </a>
            <span class="eyebrow">Không gian sáng tạo với AI</span>
            <h1>Tạo ngân hàng câu hỏi từ tài liệu</h1>
            <p>
                AI đọc nội dung đã lập chỉ mục của
                <strong>@Model.Options.Subject.Code - @Model.Options.Subject.Name</strong>,
                sau đó tạo câu hỏi kèm đáp án, giải thích và nguồn tham khảo.
            </p>
        </div>
        <span class="learning-icon learning-icon-xl">
            <i data-lucide="wand-sparkles"></i>
        </span>
    </div>

    <form method="post" class="learning-form-layout" id="generateQuestionsForm">
        <div class="learning-form-main">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <section class="surface-card learning-form-section">
                <div class="form-section-title">
                    <span>01</span>
                    <div>
                        <h2>Chọn phạm vi kiến thức</h2>
                        <p>Chỉ những tài liệu đã lập chỉ mục mới được dùng để tạo câu hỏi.</p>
                    </div>
                </div>

                @if (Model.Options.Documents.Count == 0)
                {
                    <div class="learning-empty-inline compact">
                        <span class="learning-icon"><i data-lucide="file-warning"></i></span>
                        <div>
                            <h3>Chưa có tài liệu sẵn sàng</h3>
                            <p>Hãy tải lên và lập chỉ mục ít nhất một tài liệu trước khi sử dụng AI.</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="document-select-toolbar">
                        <span>@Model.Options.Documents.Count tài liệu sẵn sàng</span>
                        <div>
                            <button type="button" class="text-button" data-select-documents="all">Chọn tất cả</button>
                            <button type="button" class="text-button" data-select-documents="none">Bỏ chọn</button>
                        </div>
                    </div>
                    <div class="document-option-grid">
                        @foreach (var document in Model.Options.Documents)
                        {
                            var isChecked = Model.Input.DocumentIds.Contains(document.Id);
                            <label class="document-option">
                                <input type="checkbox"
                                       name="Input.DocumentIds"
                                       value="@document.Id"
                                       checked="@isChecked" />
                                <span class="document-option-check"><i data-lucide="check"></i></span>
                                <span class="learning-icon"><i data-lucide="file-text"></i></span>
                                <span class="document-option-copy">
                                    <strong>@document.Name</strong>
                                    <small>@(document.ChapterName ?? "Chưa gắn chương") · @document.FileType.ToUpperInvariant()</small>
                                </span>
                            </label>
                        }
                    </div>
                }

                <div class="form-field mt-4">
                    <label asp-for="Input.ChapterId">Giới hạn theo chương</label>
                    <select asp-for="Input.ChapterId" class="form-select">
                        <option value="">Toàn bộ nội dung đã chọn</option>
                        @foreach (var chapter in Model.Options.Chapters)
                        {
                            <option value="@chapter.Id">Chương @chapter.Number: @chapter.Title</option>
                        }
                    </select>
                    <span class="form-hint">Nếu chọn chương, hệ thống chỉ dùng các đoạn tài liệu thuộc chương đó.</span>
                </div>
            </section>

            <section class="surface-card learning-form-section">
                <div class="form-section-title">
                    <span>02</span>
                    <div>
                        <h2>Thiết lập câu hỏi</h2>
                        <p>Trộn nhiều dạng câu hỏi để tăng khả năng ghi nhớ và vận dụng.</p>
                    </div>
                </div>

                <div class="question-type-grid">
                    <label class="question-type-option">
                        <input asp-for="Input.MultipleChoice" />
                        <span class="learning-icon"><i data-lucide="list-checks"></i></span>
                        <strong>Nhiều lựa chọn</strong>
                        <small>Bốn phương án, một đáp án đúng.</small>
                    </label>
                    <label class="question-type-option">
                        <input asp-for="Input.TrueFalse" />
                        <span class="learning-icon learning-icon-violet"><i data-lucide="split"></i></span>
                        <strong>Đúng hoặc sai</strong>
                        <small>Kiểm tra nhận định và khái niệm.</small>
                    </label>
                    <label class="question-type-option">
                        <input asp-for="Input.ShortAnswer" />
                        <span class="learning-icon learning-icon-amber"><i data-lucide="text-cursor-input"></i></span>
                        <strong>Trả lời ngắn</strong>
                        <small>Gợi nhớ chủ động bằng từ khóa.</small>
                    </label>
                </div>

                <div class="form-grid mt-4">
                    <div class="form-field">
                        <label asp-for="Input.QuestionCount">Số câu hỏi</label>
                        <input asp-for="Input.QuestionCount" class="form-control" type="number" min="1" max="30" />
                        <span asp-validation-for="Input.QuestionCount" class="text-danger"></span>
                    </div>
                    <div class="form-field">
                        <label asp-for="Input.Difficulty">Mức độ</label>
                        <select asp-for="Input.Difficulty" class="form-select">
                            <option value="@LearningDifficultyLevels.Mixed">Phối hợp nhiều mức độ</option>
                            <option value="@LearningDifficultyLevels.Easy">Cơ bản</option>
                            <option value="@LearningDifficultyLevels.Medium">Trung bình</option>
                            <option value="@LearningDifficultyLevels.Hard">Nâng cao</option>
                        </select>
                    </div>
                </div>

                <div class="form-field mt-4">
                    <label asp-for="Input.Focus">Trọng tâm dành cho AI</label>
                    <textarea asp-for="Input.Focus"
                              class="form-control"
                              rows="4"
                              placeholder="Ví dụ: tập trung vào vòng đời request, dependency injection và các lỗi sinh viên thường gặp."></textarea>
                    <span asp-validation-for="Input.Focus" class="text-danger"></span>
                </div>
            </section>
        </div>

        <aside class="learning-form-aside">
            <div class="surface-card generation-summary">
                <span class="eyebrow">Quy trình kiểm soát</span>
                <h2>Nội dung được kiểm tra trước khi lưu</h2>
                <ul class="quality-list">
                    <li><i data-lucide="check-circle-2"></i> Đúng phạm vi môn học và tài liệu.</li>
                    <li><i data-lucide="check-circle-2"></i> Loại câu hỏi, phương án và đáp án hợp lệ.</li>
                    <li><i data-lucide="check-circle-2"></i> Loại bỏ câu trùng trong ngân hàng đề.</li>
                    <li><i data-lucide="check-circle-2"></i> Lưu giải thích và nguồn để giảng viên rà soát.</li>
                </ul>
                <button class="btn btn-primary btn-lg w-100"
                        type="submit"
                        @(Model.Options.Documents.Count == 0 ? "disabled" : null)>
                    <i data-lucide="sparkles" class="icon-sm"></i>
                    Tạo và lưu câu hỏi
                </button>
                <p class="generation-note">
                    Thời gian xử lý phụ thuộc số lượng và độ dài tài liệu. Không đóng trang trong khi AI đang tạo nội dung.
                </p>
            </div>
        </aside>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-select-documents]').forEach(button => {
            button.addEventListener('click', () => {
                const shouldCheck = button.dataset.selectDocuments === 'all';
                document.querySelectorAll('input[name="Input.DocumentIds"]').forEach(input => {
                    input.checked = shouldCheck;
                });
            });
        });

        document.getElementById('generateQuestionsForm')?.addEventListener('submit', event => {
            const submitButton = event.currentTarget.querySelector('button[type="submit"]');
            if (!submitButton || !event.currentTarget.checkValidity()) return;
            submitButton.disabled = true;
            submitButton.innerHTML = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span> AI đang tạo câu hỏi...';
        });
    </script>
}
