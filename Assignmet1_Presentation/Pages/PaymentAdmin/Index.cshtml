@page "/PaymentAdmin/Index"
@model Assignmet1_Presentation.Pages.PaymentAdmin.IndexModel
@using Assignmet1_Presentation.Constants
@{
    ViewData["Title"] = "Giao dịch MoMo";
    string StatusLabel(string status) => status switch
    {
        PaymentStatuses.MomoPending => "Đang chờ xác nhận",
        PaymentStatuses.Approved => "Thành công",
        PaymentStatuses.Rejected => "Thất bại",
        _ => "Đang xử lý"
    };
    string StatusBadge(string status) => status switch
    {
        PaymentStatuses.MomoPending => "bg-info text-dark",
        PaymentStatuses.Approved => "bg-success",
        PaymentStatuses.Rejected => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

<section class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="hero-badge mb-3"><i data-lucide="receipt-text" class="icon-sm"></i> Đối soát thanh toán</div>
            <h1 class="page-title">Lịch sử giao dịch MoMo</h1>
            <p class="page-subtitle mb-0">@Model.ViewModel.PendingCount giao dịch đang chờ MoMo xác nhận</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-light filter-chip @(Model.ViewModel.StatusFilter is null ? "active" : "")" asp-page="/PaymentAdmin/Index">Tất cả</a>
            <a class="btn btn-outline-warning filter-chip @(Model.ViewModel.StatusFilter == PaymentStatuses.Pending ? "active" : "")" asp-page="/PaymentAdmin/Index" asp-route-status="@PaymentStatuses.Pending">Đang xử lý</a>
            <a class="btn btn-outline-success filter-chip @(Model.ViewModel.StatusFilter == PaymentStatuses.Approved ? "active" : "")" asp-page="/PaymentAdmin/Index" asp-route-status="@PaymentStatuses.Approved">Thành công</a>
            <a class="btn btn-outline-danger filter-chip @(Model.ViewModel.StatusFilter == PaymentStatuses.Rejected ? "active" : "")" asp-page="/PaymentAdmin/Index" asp-route-status="@PaymentStatuses.Rejected">Thất bại</a>
        </div>
    </div>
</section>

@if (!Model.ViewModel.Tickets.Any())
{
    <div class="content-panel text-center py-5">Chưa có giao dịch nào.</div>
}
else
{
    var ticketsPagination = Model.TicketsPagination.ToViewModel(
        "/PaymentAdmin/Index",
        "pageNumber",
        "giao dịch",
        new Dictionary<string, object?>
        {
            ["status"] = Model.ViewModel.StatusFilter
        });

    <div class="surface-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Người dùng</th>
                        <th>Gói học</th>
                        <th>Số tiền</th>
                        <th>Mã đơn</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model.ViewModel.Tickets)
                    {
                        <tr>
                            <td>@ticket.Id</td>
                            <td>
                                <strong>@(ticket.FullName ?? ticket.Username)</strong><br />
                                <small class="text-muted">@ticket.Email</small>
                            </td>
                            <td>@ticket.PlanName</td>
                            <td>@ticket.Amount.ToString("N0") đ</td>
                            <td>@(string.IsNullOrWhiteSpace(ticket.TransferReference) ? "-" : ticket.TransferReference)</td>
                            <td><span class="status-chip @StatusBadge(ticket.Status)">@StatusLabel(ticket.Status)</span></td>
                            <td>@(ticket.CreatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(ticket.AdminNote))
                                {
                                    <div>@ticket.AdminNote</div>
                                }
                                else if (ticket.Status == PaymentStatuses.MomoPending)
                                {
                                    <small class="text-muted">Hệ thống đang chờ IPN hoặc callback từ MoMo.</small>
                                }
                                else
                                {
                                    <small class="text-muted">-</small>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <partial name="_Pagination" model="ticketsPagination" />
    </div>
}
