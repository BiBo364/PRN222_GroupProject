<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f4f7ff" />
    <title>@ViewData["Title"] - RAG Edu Hub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- FontAwesome (backup) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
          integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- SweetAlert2 -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
</head>
<body class="app-body" data-page-path="@Context.Request.Path.Value">
    @{
        var isLoggedIn        = Context.Session.GetInt32("UserId") is not null;
        var forcePasswordChange = string.Equals(Context.Session.GetString("ForcePasswordChange"), "true", StringComparison.OrdinalIgnoreCase);
        var sessionRoleId     = Context.Session.GetInt32("RoleId");
        var sessionFullName   = Context.Session.GetString("FullName");
        var sessionUsername   = Context.Session.GetString("Username");

        // Role display info
        string roleLabel = sessionRoleId switch {
            1 => "Quản trị viên",
            2 => "Giảng viên",
            3 => "Sinh viên",
            _ => ""
        };
        string roleCssClass = sessionRoleId switch {
            1 => "warning",
            2 => "primary",
            3 => "success",
            _ => "info"
        };

        var successMsg = TempData["Success"] as string;
        var warningMsg = TempData["Warning"] as string;
        var errorMsg   = TempData["Error"] as string;
        var infoMsg    = TempData["Info"] as string;

        TempData.Remove("Success");
        TempData.Remove("Warning");
        TempData.Remove("Error");
        TempData.Remove("Info");

        var flashMessages = new List<string>();
        var flashCss = "alert-info";
        var flashIcon = "info";

        if (!string.IsNullOrWhiteSpace(errorMsg))
        {
            flashCss = "alert-danger";
            flashIcon = "x-circle";
            flashMessages.Add(errorMsg);
        }

        if (!string.IsNullOrWhiteSpace(warningMsg))
        {
            if (flashMessages.Count == 0)
            {
                flashCss = "alert-warning";
                flashIcon = "alert-triangle";
            }
            flashMessages.Add(warningMsg);
        }

        if (!string.IsNullOrWhiteSpace(successMsg))
        {
            if (flashMessages.Count == 0)
            {
                flashCss = "alert-success";
                flashIcon = "check-circle-2";
            }
            flashMessages.Add(successMsg);
        }

        if (!string.IsNullOrWhiteSpace(infoMsg))
        {
            flashMessages.Add(infoMsg);
        }
    }

    <div class="app-scroll-progress" data-scroll-progress aria-hidden="true"></div>
    <div class="app-ambient" aria-hidden="true">
        <span class="app-ambient-orb app-ambient-orb-one"></span>
        <span class="app-ambient-orb app-ambient-orb-two"></span>
        <span class="app-ambient-orb app-ambient-orb-three"></span>
    </div>

    <header class="app-header" data-app-header>
        <nav class="navbar navbar-expand-lg app-nav">
            <div class="container app-shell">

                <!-- Brand -->
                <a class="navbar-brand app-brand" asp-page="/Home/Index">
                    <span class="brand-mark">
                        <i data-lucide="book-open" class="icon-md text-white"></i>
                    </span>
                    <span class="brand-text">RAG Edu Hub</span>
                </a>

                <!-- Toggle -->
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Mở hoặc đóng trình đơn">
                    <i data-lucide="menu" class="icon-md" style="color:var(--text-muted)"></i>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">

                    <!-- Left links -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 app-nav-links">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Home/Index">
                                <i data-lucide="home" class="icon-sm"></i> Trang chủ
                            </a>
                        </li>

                        @if (isLoggedIn && !forcePasswordChange)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Documents/Index">
                                    <i data-lucide="library" class="icon-sm"></i> Thư viện
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Chat/Index">
                                    <i data-lucide="message-square" class="icon-sm"></i> Chat AI
                                </a>
                            </li>
                            @if (sessionRoleId is 2 or 3)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Learning/Index">
                                        <i data-lucide="brain-circuit" class="icon-sm"></i> Ôn tập
                                    </a>
                                </li>
                            }
                            @if (sessionRoleId != 1)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Subscription/Index">
                                        <i data-lucide="sparkles" class="icon-sm"></i> Gói học
                                    </a>
                                </li>
                            }

                            @* Recycle bin for Lecturer (own subject docs) *@
                            @if (sessionRoleId == 2)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Documents/Recycle">
                                        <i data-lucide="archive-restore" class="icon-sm"></i> Thùng rác tài liệu
                                    </a>
                                </li>
                            }

                            @* Admin menu *@
                            @if (sessionRoleId == 1)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i data-lucide="shield-check" class="icon-sm"></i> Quản trị
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li>
                                            <span class="dropdown-header text-uppercase" style="font-size:.68rem;letter-spacing:.07em;color:var(--text-faint);padding:.4rem .85rem .2rem">
                                                Môn học
                                            </span>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Subjects/Manage">
                                                <i data-lucide="book-copy" class="icon-sm"></i> Quản lý môn học
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Subjects/Recycle">
                                                <i data-lucide="trash-2" class="icon-sm" style="color:var(--rose)"></i> Thùng rác môn học
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <span class="dropdown-header text-uppercase" style="font-size:.68rem;letter-spacing:.07em;color:var(--text-faint);padding:.4rem .85rem .2rem">
                                                Người dùng
                                            </span>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Admin/Index">
                                                <i data-lucide="users" class="icon-sm"></i> Quản lý người dùng
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Admin/ImportUsers">
                                                <i data-lucide="file-up" class="icon-sm"></i> Nhập người dùng
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Audit/Index">
                                                <i data-lucide="scroll-text" class="icon-sm"></i> Nhật ký thao tác
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <span class="dropdown-header text-uppercase" style="font-size:.68rem;letter-spacing:.07em;color:var(--text-faint);padding:.4rem .85rem .2rem">
                                                Tài chính
                                            </span>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/Subscription/Index">
                                                <i data-lucide="credit-card" class="icon-sm"></i> Gói học
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-page="/PaymentAdmin/Index">
                                                <i data-lucide="receipt" class="icon-sm"></i> Giao dịch
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }
                        }
                        else if (isLoggedIn && forcePasswordChange)
                        {
                            <li class="nav-item">
                                <span class="force-password-nav">
                                    <i data-lucide="alert-circle" class="icon-sm"></i>
                                    Vui lòng đổi mật khẩu để tiếp tục
                                </span>
                            </li>
                        }
                    </ul>

                    <!-- Right meta -->
                    <div class="d-flex align-items-center gap-2 app-nav-meta">
                        @if (isLoggedIn)
                        {
                            <div class="dropdown">
                                <button class="user-chip dropdown-toggle border-0" data-bs-toggle="dropdown">
                                    <span class="user-chip-label">Đã đăng nhập</span>
                                    <div class="d-flex align-items-center gap-2">
                                        <strong class="text-truncate" style="max-width:140px;font-size:.88rem">
                                            @(sessionFullName ?? sessionUsername)
                                        </strong>
                                        @if (!string.IsNullOrEmpty(roleLabel))
                                        {
                                            <span class="status-chip @roleCssClass" style="font-size:.65rem;padding:.15rem .55rem;font-weight:700">
                                                @roleLabel
                                            </span>
                                        }
                                    </div>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" style="min-width:220px">
                                    <li class="px-3 py-2">
                                        <div style="font-size:.72rem;color:var(--text-faint);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.2rem">
                                            Tài khoản
                                        </div>
                                        <div class="fw-semibold" style="font-size:.9rem;color:var(--text)">
                                            @(sessionFullName ?? sessionUsername)
                                        </div>
                                        @if (!string.IsNullOrEmpty(roleLabel))
                                        {
                                            <span class="status-chip @roleCssClass mt-1" style="font-size:.7rem;padding:.2rem .6rem">
                                                @roleLabel
                                            </span>
                                        }
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    @if (sessionRoleId == 3)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-page="/Subscription/Index">
                                                <i data-lucide="sparkles" class="icon-sm"></i> Gói Plus của tôi
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                    }
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/ChangePassword">
                                            <i data-lucide="key-round" class="icon-sm"></i> Đổi mật khẩu
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/Logout" style="color:var(--rose-dk)">
                                            <i data-lucide="log-out" class="icon-sm"></i> Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-primary btn-sm" asp-page="/Account/Login">
                                <i data-lucide="log-in" class="icon-sm"></i> Đăng nhập
                            </a>
                        }
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="app-main page-stage">
        <div class="container app-shell">

            @* Global flash messages *@
            @if (flashMessages.Count > 0)
            {
                <div class="alert @flashCss mb-4" role="alert">
                    <i data-lucide="@flashIcon" class="alert-icon"></i>
                    <div>
                        @foreach (var message in flashMessages)
                        {
                            <div>@message</div>
                        }
                    </div>
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="container app-shell d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
            <div class="d-flex align-items-center gap-2">
                <span class="brand-mark" style="width:1.6rem;height:1.6rem;border-radius:.4rem">
                    <i data-lucide="book-open" style="width:14px;height:14px;color:#fff"></i>
                </span>
                <div>
                    <span class="app-footer-brand">RAG Edu Hub</span>
                    <span class="app-footer-note">Học liệu thông minh, ôn tập chủ động.</span>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="app-footer-copyright">&copy; 2026</span>
                <a asp-page="/Home/Privacy" class="app-footer-link">Chính sách riêng tư</a>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
