@page "/Subjects/Create"
@model Assignmet1_Presentation.Pages.Subjects.CreateModel
@{
    ViewData["Title"] = "Tạo môn học";
}

<section class="page-hero mb-4">
    <div class="hero-badge mb-3"><i data-lucide="plus-circle" class="icon-sm"></i> Thêm môn học mới</div>
    <h1 class="page-title mb-2">Tạo môn học</h1>
    <p class="page-subtitle mb-0">Thêm một môn học mới vào hệ thống.</p>
</section>


<div class="surface-card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Input.Code" class="form-label">Mã môn học</label>
            <input asp-for="Input.Code" class="form-control" placeholder="Ví dụ: CS301" />
            <span asp-validation-for="Input.Code" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Name" class="form-label">Tên môn học</label>
            <input asp-for="Input.Name" class="form-control" placeholder="Ví dụ: Trí Tuệ Nhân Tạo" />
            <span asp-validation-for="Input.Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Description" class="form-label">Mô tả</label>
            <textarea asp-for="Input.Description" class="form-control" rows="4" placeholder="Mô tả ngắn gọn về môn học"></textarea>
            <span asp-validation-for="Input.Description" class="text-danger"></span>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary"><i data-lucide="check" class="icon-sm me-2"></i> Tạo môn học</button>
            <a asp-page="/Documents/Index" class="btn btn-outline-secondary"><i data-lucide="arrow-left" class="icon-sm me-2"></i> Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}