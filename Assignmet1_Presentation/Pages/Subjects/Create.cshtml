@page "/Subjects/Create"
@model Assignmet1_Presentation.Pages.Subjects.CreateModel
@{
    ViewData["Title"] = "Tạo môn học";
}

<section class="page-hero mb-4">
    <div class="hero-badge mb-3"><i data-lucide="plus-circle" class="icon-sm"></i> Thiết lập môn học</div>
    <h1 class="page-title mb-2">Tạo không gian môn học mới</h1>
    <p class="page-subtitle mb-0">
        Khởi tạo mã môn, tên hiển thị và phần giới thiệu trước khi phân công giảng viên hoặc thêm học liệu.
    </p>
</section>

<div class="editor-layout">
    <div class="surface-card editor-form-card">
        <div class="editor-form-heading">
            <div class="editor-form-icon"><i data-lucide="book-plus"></i></div>
            <div>
                <h2>Thông tin cơ bản</h2>
                <p>Các trường có dấu sao là bắt buộc.</p>
            </div>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

            <div class="form-field">
                <label asp-for="Input.Code" class="form-label">Mã môn học <span class="text-danger">*</span></label>
                <input asp-for="Input.Code" class="form-control" placeholder="Ví dụ: PRN222" autocomplete="off" />
                <div class="form-text">Dùng mã ngắn, dễ nhận biết và không trùng với môn học khác.</div>
                <span asp-validation-for="Input.Code" class="text-danger"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.Name" class="form-label">Tên môn học <span class="text-danger">*</span></label>
                <input asp-for="Input.Name" class="form-control" placeholder="Ví dụ: Lập trình Web với ASP.NET Core" />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.Description" class="form-label">Mô tả</label>
                <textarea asp-for="Input.Description" class="form-control" rows="5"
                          placeholder="Mô tả mục tiêu, nội dung chính hoặc phạm vi kiến thức của môn học."></textarea>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>

            <div class="editor-actions">
                <button type="submit" class="btn btn-primary">
                    <i data-lucide="check" class="icon-sm"></i>
                    Tạo môn học
                </button>
                <a asp-page="/Subjects/Manage" class="btn btn-outline-secondary">
                    <i data-lucide="arrow-left" class="icon-sm"></i>
                    Quay lại danh sách
                </a>
            </div>
        </form>
    </div>

    <aside class="editor-aside">
        <div class="editor-aside-card">
            <div class="editor-aside-icon"><i data-lucide="list-checks"></i></div>
            <h3>Chuẩn bị trước khi tạo</h3>
            <ul class="editor-checklist">
                <li><i data-lucide="check-circle-2"></i><span>Thống nhất mã môn học với chương trình đào tạo.</span></li>
                <li><i data-lucide="check-circle-2"></i><span>Viết tên đầy đủ để sinh viên dễ tìm kiếm.</span></li>
                <li><i data-lucide="check-circle-2"></i><span>Mô tả ngắn gọn phạm vi kiến thức sẽ giảng dạy.</span></li>
            </ul>
        </div>
        <div class="editor-aside-card">
            <div class="editor-aside-icon"><i data-lucide="route"></i></div>
            <h3>Bước tiếp theo</h3>
            <p>Sau khi tạo môn học, hãy phân công giảng viên và tải tài liệu để kích hoạt Chat AI cùng không gian sáng tạo nội dung bằng AI.</p>
        </div>
    </aside>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
