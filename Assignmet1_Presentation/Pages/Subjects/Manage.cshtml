@page "/Subjects/Manage"
@model Assignmet1_Presentation.Pages.Subjects.ManageModel
@{
    ViewData["Title"] = "Quản lý môn học";
}

<div class="d-flex flex-column gap-4">

    <!-- Hidden antiforgery form for realtime JS -->
    <form id="subjects-antiforgery" method="post" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <!-- ── HERO ──────────────────────────────────────────────────── -->
    <div class="page-hero d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div>
            <div class="hero-badge mb-2">
                <i data-lucide="shield-check" class="icon-sm"></i> Quản trị
            </div>
            <h1 class="page-title mb-1">Quản lý môn học</h1>
            <p class="page-subtitle">Tạo, cập nhật và xóa thông tin các môn học trong hệ thống.</p>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
            <a asp-page="/Subjects/Recycle" class="btn btn-outline-secondary">
                <i data-lucide="trash-2" class="icon-sm"></i> Thùng rác
            </a>
            <a asp-page="/Subjects/Create" class="btn btn-primary">
                <i data-lucide="plus" class="icon-sm"></i> Thêm môn học
            </a>
        </div>
    </div>

    <!-- ── ALERTS ─────────────────────────────────────────────────── -->

    <!-- ── TABLE CARD ─────────────────────────────────────────────── -->
    <div class="surface-card p-0 overflow-hidden">

        <div class="card-header-row">
            <h2 class="card-header-title">
                <i data-lucide="book-copy" class="icon-sm me-1" style="color:var(--primary)"></i>
                Danh sách môn học —
                <span id="subject-count">@Model.SubjectsPagination.TotalItems</span> môn
            </h2>
            <a asp-page="/Subjects/Create" class="btn btn-primary btn-sm d-none d-md-inline-flex">
                <i data-lucide="plus" class="icon-sm"></i> Thêm mới
            </a>
        </div>

        <!-- Empty state -->
        <div id="subject-empty-state"
             class="empty-state"
             style="display:@(Model.Subjects.Count == 0 ? "block" : "none")">
            <div class="empty-state-icon">
                <i data-lucide="book-open" style="width:56px;height:56px;color:var(--text-faint)"></i>
            </div>
            <div class="empty-state-title">Chưa có môn học nào</div>
            <div class="empty-state-desc">Bắt đầu bằng cách tạo môn học đầu tiên để phân công giảng viên và quản lý tài liệu.</div>
            <a asp-page="/Subjects/Create" class="btn btn-primary">
                <i data-lucide="plus" class="icon-sm"></i> Tạo môn học đầu tiên
            </a>
        </div>

        <!-- Table -->
        <div id="subject-table-wrapper"
             class="table-responsive"
             style="display:@(Model.Subjects.Count == 0 ? "none" : "block")">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th class="ps-4" style="width:140px">Mã môn</th>
                        <th>Tên môn học</th>
                        <th style="width:160px">Số tài liệu</th>
                        <th class="pe-4 text-end" style="width:160px">Hành động</th>
                    </tr>
                </thead>
                <tbody id="subject-table-body">
                    @foreach (var subject in Model.Subjects)
                    {
                        <tr data-subject-row
                            data-subject-id="@subject.Id"
                            data-subject-code="@subject.Code">
                            <td class="ps-4">
                                <span class="status-chip primary" style="font-size:.8rem;font-weight:700">
                                    @subject.Code
                                </span>
                            </td>
                            <td>
                                <div class="fw-semibold subject-name" style="color:var(--text)">@subject.Name</div>
                                <div class="text-muted small subject-description" style="font-size:.8rem;margin-top:.15rem">
                                    @(string.IsNullOrEmpty(subject.Description) ? "Không có mô tả" : subject.Description)
                                </div>
                            </td>
                            <td>
                                <span class="status-chip info">
                                    <i data-lucide="file-text" class="icon-xs"></i>
                                    <span class="subject-document-count">@subject.DocumentCount</span> tài liệu
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="action-btn-group">
                                    <a asp-page="/Subjects/Details"
                                       asp-route-id="@subject.Id"
                                       class="btn btn-sm btn-outline-info"
                                       title="Xem chi tiết môn học">
                                        <i data-lucide="eye" class="icon-sm"></i>
                                    </a>
                                    <a asp-page="/Subjects/Edit"
                                       asp-route-id="@subject.Id"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Chỉnh sửa môn học">
                                        <i data-lucide="pencil" class="icon-sm"></i>
                                    </a>
                                    <form asp-page-handler="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@subject.Id" />
                                        <input type="hidden" name="PageNumber" value="@Model.SubjectsPagination.CurrentPage" />
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger btn-delete-confirm"
                                                data-item-name="môn học @subject.Code - @subject.Name"
                                                data-item-type="môn học"
                                                data-can-restore="true"
                                                title="Xóa môn học (có thể khôi phục)">
                                            <i data-lucide="trash-2" class="icon-sm"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @{
            var subjectsPagination = Model.SubjectsPagination.ToViewModel(
                "/Subjects/Manage",
                "pageNumber",
                "môn học",
                fragment: "subject-table-wrapper");
        }
        <partial name="_Pagination" model="subjectsPagination" />
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const grid        = document.getElementById("subject-table-body");
            const emptyState  = document.getElementById("subject-empty-state");
            const tableWrapper = document.getElementById("subject-table-wrapper");
            const countNode   = document.getElementById("subject-count");
            const tokenInput  = document.querySelector("#subjects-antiforgery input[name='__RequestVerificationToken']");
            const requestToken = tokenInput ? tokenInput.value : "";

            if (!grid) return;

            function subjectRowHtml(subject) {
                const desc = subject.description
                    ? appHubRealtime.escapeHtml(subject.description)
                    : "Không có mô tả";
                return `
                    <tr data-subject-row data-subject-id="${subject.id}" data-subject-code="${appHubRealtime.escapeHtml(subject.code)}">
                        <td class="ps-4">
                            <span class="status-chip primary" style="font-size:.8rem;font-weight:700">
                                ${appHubRealtime.escapeHtml(subject.code)}
                            </span>
                        </td>
                        <td>
                            <div class="fw-semibold subject-name" style="color:var(--text)">${appHubRealtime.escapeHtml(subject.name)}</div>
                            <div class="text-muted small subject-description" style="font-size:.8rem;margin-top:.15rem">${desc}</div>
                        </td>
                        <td>
                            <span class="status-chip info">
                                <i data-lucide="file-text" class="icon-xs"></i>
                                <span class="subject-document-count">${subject.documentCount ?? 0}</span> tài liệu
                            </span>
                        </td>
                        <td class="pe-4 text-end">
                            <div class="action-btn-group">
                                <a href="/Subjects/Details/${subject.id}" class="btn btn-sm btn-outline-info" title="Xem chi tiết">
                                    <i data-lucide="eye" class="icon-sm"></i>
                                </a>
                                <a href="/Subjects/Edit/${subject.id}" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                    <i data-lucide="pencil" class="icon-sm"></i>
                                </a>
                                <form method="post" action="?handler=Delete" class="d-inline">
                                    <input type="hidden" name="__RequestVerificationToken" value="${requestToken}" />
                                    <input type="hidden" name="id" value="${subject.id}" />
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger btn-delete-confirm"
                                            data-item-name="môn học ${appHubRealtime.escapeHtml(subject.code)}"
                                            data-item-type="môn học"
                                            data-can-restore="true"
                                            title="Xóa môn học">
                                        <i data-lucide="trash-2" class="icon-sm"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>`;
            }

            function updateEmptyState() {
                const rows = grid.querySelectorAll("[data-subject-row]");
                if (emptyState)   emptyState.style.display   = rows.length === 0 ? "block" : "none";
                if (tableWrapper) tableWrapper.style.display = rows.length === 0 ? "none"  : "block";
            }

            function sortRows() {
                const rows = Array.from(grid.querySelectorAll("[data-subject-row]"));
                rows.sort((a, b) =>
                    (a.getAttribute("data-subject-code") || "").localeCompare(b.getAttribute("data-subject-code") || "")
                );
                rows.forEach(row => grid.appendChild(row));
            }

            function upsertSubject(subject) {
                const existing = grid.querySelector(`[data-subject-row][data-subject-id="${subject.id}"]`);
                if (existing) {
                    existing.setAttribute("data-subject-code", subject.code || "");
                    existing.querySelector(".subject-name").textContent        = subject.name || "";
                    existing.querySelector(".subject-description").textContent = subject.description || "Không có mô tả";
                    const docCount = existing.querySelector(".subject-document-count");
                    if (docCount) docCount.textContent = String(subject.documentCount ?? 0);
                } else {
                    window.location.reload();
                    return;
                }
                sortRows();
                updateEmptyState();
            }

            function removeSubject(id) {
                const row = grid.querySelector(`[data-subject-row][data-subject-id="${id}"]`);
                if (row) row.remove();
                window.location.reload();
            }

            updateEmptyState();

            window.subjectRealtime = window.appHubRealtime.createConnection({
                CourseCreated: upsertSubject,
                CourseUpdated: upsertSubject,
                CourseDeleted: removeSubject
            });
        })();
    </script>
}
