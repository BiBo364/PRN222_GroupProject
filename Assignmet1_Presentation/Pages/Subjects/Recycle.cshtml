@page "/Subjects/Recycle"
@model Assignmet1_Presentation.Pages.Subjects.RecycleModel
@{
    ViewData["Title"] = "Thùng rác môn học";
}

<div class="d-flex flex-column gap-4">
    <!-- ── HERO ──────────────────────────────────────────────────── -->
    <div class="page-hero d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div>
            <div class="hero-badge mb-2">
                <i data-lucide="trash-2" class="icon-sm text-danger"></i> Thùng rác
            </div>
            <h1 class="page-title mb-1">Môn học đã xóa</h1>
            <p class="page-subtitle">Xem và khôi phục các môn học đã bị xóa khỏi hệ thống.</p>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
            <a asp-page="/Subjects/Manage" class="btn btn-outline-secondary">
                <i data-lucide="arrow-left" class="icon-sm"></i> Quay lại Quản lý
            </a>
        </div>
    </div>

    <!-- ── ALERTS ─────────────────────────────────────────────────── -->

    <!-- ── TABLE ─────────────────────────────────────────────────── -->
    <div class="surface-card p-0 overflow-hidden">
        <div class="card-header-row">
            <h2 class="card-header-title">
                <i data-lucide="trash" class="icon-sm me-1" style="color:var(--rose)"></i>
                Danh sách môn học đã xóa (@Model.SubjectsPagination.TotalItems)
            </h2>
        </div>

        @if (Model.Subjects.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i data-lucide="archive-restore" style="width:56px;height:56px;color:var(--text-faint)"></i>
                </div>
                <div class="empty-state-title">Thùng rác trống</div>
                <div class="empty-state-desc">Không có môn học nào đã bị xóa.</div>
            </div>
        }
        else
        {
            var subjectsPagination = Model.SubjectsPagination.ToViewModel(
                "/Subjects/Recycle",
                "pageNumber",
                "môn học đã xóa");

            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">Mã môn học</th>
                            <th>Tên môn học</th>
                            <th>Người xóa</th>
                            <th>Ngày xóa</th>
                            <th class="pe-4 text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var subject in Model.Subjects)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="status-chip primary" style="font-size:.8rem;font-weight:700">
                                        @subject.Code
                                    </span>
                                </td>
                                <td>
                                    <div class="fw-semibold" style="color:var(--text)">@subject.Name</div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="user-avatar-circle" style="width:24px;height:24px;font-size:.65rem;background:linear-gradient(135deg,#64748b,#64748baa)">
                                            @((subject.DeletedByName?.Length > 0 ? subject.DeletedByName[0] : '?').ToString().ToUpper())
                                        </div>
                                        <span style="font-size:.85rem;color:var(--text-sec)">@(subject.DeletedByName ?? "Không rõ")</span>
                                    </div>
                                </td>
                                <td>
                                    <span style="font-size:.85rem;color:var(--text-muted)">
                                        @(subject.DeletedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                                    </span>
                                </td>
                                <td class="pe-4 text-end">
                                    <form asp-page-handler="Restore" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@subject.Id" />
                                        <input type="hidden" name="PageNumber" value="@Model.SubjectsPagination.CurrentPage" />
                                        <button type="button"
                                                class="btn btn-sm btn-outline-success btn-restore"
                                                data-item-name="@subject.Code - @subject.Name"
                                                title="Khôi phục môn học">
                                            <i data-lucide="rotate-ccw" class="icon-sm"></i> Khôi phục
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <partial name="_Pagination" model="subjectsPagination" />
        }
    </div>
</div>

<!-- ── Modal: Confirm Restore ────────────────────────────────── -->
<div class="modal fade" id="restoreSubjectModal" tabindex="-1" aria-labelledby="restoreSubjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-success" id="restoreSubjectModalLabel">
                    <i data-lucide="rotate-ccw" class="icon-md me-2"></i> Xác nhận khôi phục
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body" style="font-size:.9rem;color:var(--text-sec)">
                Bạn có chắc chắn muốn khôi phục môn học <strong id="restoreSubjectName" style="color:var(--primary)"></strong> không?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i data-lucide="x" class="icon-sm"></i> Hủy bỏ
                </button>
                <button type="button" class="btn btn-success" id="confirmRestoreBtn">
                    <i data-lucide="check" class="icon-sm"></i> Khôi phục
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            let formToSubmit = null;
            const modalEl = document.getElementById('restoreSubjectModal');
            const restoreModal = modalEl ? new bootstrap.Modal(modalEl) : null;

            document.querySelectorAll('.btn-restore').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    formToSubmit = e.target.closest('form');
                    const name = btn.getAttribute('data-item-name');
                    document.getElementById('restoreSubjectName').textContent = name;
                    if (restoreModal) restoreModal.show();
                });
            });

            const confirmBtn = document.getElementById('confirmRestoreBtn');
            if (confirmBtn) {
                confirmBtn.addEventListener('click', () => {
                    if (formToSubmit) formToSubmit.submit();
                    if (restoreModal) restoreModal.hide();
                });
            }
        });
    </script>
}
