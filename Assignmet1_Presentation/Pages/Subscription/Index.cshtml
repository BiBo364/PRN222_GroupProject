@page "/Subscription/Index"
@model Assignmet1_Presentation.Pages.Subscription.IndexModel
@using Assignmet1_Presentation.Constants
@{
    ViewData["Title"] = "Gói Plus";
    var nextResetAt = Model.ViewModel.NextResetAt;
    string StatusLabel(string status) => status switch
    {
        PaymentStatuses.MomoPending => "Đang chờ MoMo",
        PaymentStatuses.Approved => "Thành công",
        PaymentStatuses.Rejected => "Thất bại",
        _ => "Đang xử lý"
    };
    string StatusBadge(string status) => status switch
    {
        PaymentStatuses.MomoPending => "bg-info text-dark",
        PaymentStatuses.Approved => "bg-success",
        PaymentStatuses.Rejected => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

@if (Model.ViewModel.IsAdminView)
{
    <section class="page-hero mb-4">
        <div class="hero-badge mb-3">Quản trị viên</div>
        <h1 class="page-title">Quản lý gói học và doanh thu</h1>
        <p class="page-subtitle mb-0">
            Theo dõi các gói đăng ký hiện có, tổng doanh thu, gói được mua nhiều nhất và báo cáo theo thời gian.
        </p>
    </section>

    <div class="surface-card mb-5">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
            <div>
                <div class="stat-label mb-2">Danh sách gói</div>
                <h3 class="h4 mb-0">Tất cả gói học hiện tại</h3>
            </div>
            <span class="status-chip primary">@Model.ViewModel.Plans.Count gói</span>
        </div>

        @if (!Model.ViewModel.AdminPlanReports.Any())
        {
            <div class="alert alert-warning mb-0">Chưa có gói học nào được cấu hình.</div>
        }
        else
        {
            <div class="admin-plan-card-grid">
                @foreach (var plan in Model.ViewModel.AdminPlanReports)
                {
                    <article class="surface-card plan-purchase-card admin-plan-showcase-card">
                        <div class="d-flex flex-column h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <div class="stat-label mb-2 admin-plan-kicker">Gói Plus</div>
                                    <h4 class="card-title mb-1 admin-plan-title">@plan.Name</h4>
                                    <p class="card-text admin-plan-description mb-0">@(string.IsNullOrWhiteSpace(plan.Description) ? "Không có mô tả." : plan.Description)</p>
                                </div>
                                <span class="plan-duration-pill">@plan.DurationDays ngày</span>
                            </div>

                            <div class="plan-price mb-3 admin-plan-price">@plan.Price.ToString("N0") đ</div>

                            <ul class="plan-benefits admin-plan-benefits">
                                <li><strong>@plan.PurchaseCount lượt mua thành công</strong></li>
                                <li><strong>@plan.Revenue.ToString("N0") đ doanh thu</strong></li>
                                <li><strong>Chiếm @plan.PurchaseSharePercent%</strong> tổng đơn thành công.</li>
                            </ul>
                        </div>
                    </article>
                }
            </div>
        }
    </div>

    <div class="surface-card mb-4 admin-filter-card">
        <form method="get" asp-page="/Subscription/Index" class="row g-3 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label" for="fromDate">Từ ngày</label>
                <input class="form-control" id="fromDate" name="fromDate" type="date" value="@(Model.ViewModel.FilterFromDate?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" for="toDate">Đến ngày</label>
                <input class="form-control" id="toDate" name="toDate" type="date" value="@(Model.ViewModel.FilterToDate?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-12 col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">Lọc báo cáo</button>
                <a class="btn btn-outline-light flex-fill" asp-page="/Subscription/Index">Xem toàn bộ</a>
            </div>
        </form>
        <p class="small text-muted mb-0 mt-3">
            @(Model.ViewModel.FilterFromDate.HasValue || Model.ViewModel.FilterToDate.HasValue
                ? $"Đang xem doanh thu trong khoảng {(Model.ViewModel.FilterFromDate?.ToString("dd/MM/yyyy") ?? "tất cả")} - {(Model.ViewModel.FilterToDate?.ToString("dd/MM/yyyy") ?? "hiện tại")}."
                : "Chưa chọn thời gian, hệ thống đang hiển thị toàn bộ doanh thu từ trước đến hiện tại.")
        </p>
    </div>

    <div class="subscription-summary-grid admin-summary-grid mb-4">
        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Tổng gói đang có</div>
            <div class="subscription-summary-value">@Model.ViewModel.Plans.Count</div>
            <p class="mb-0 text-muted">Tổng số gói hệ thống đang cấu hình cho sinh viên mua.</p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Tổng doanh thu</div>
            <div class="subscription-summary-value">@Model.ViewModel.AdminTotalRevenue.ToString("N0") đ</div>
            <p class="mb-0 text-muted">Chỉ tính giao dịch thành công trong khoảng đang lọc.</p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Đơn thành công</div>
            <div class="subscription-summary-value">@Model.ViewModel.AdminSuccessfulOrders</div>
            <p class="mb-0 text-muted">Tổng số đơn MoMo đã thanh toán và kích hoạt gói thành công.</p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Gói mua nhiều nhất</div>
            <div class="subscription-summary-value">@Model.ViewModel.AdminTopPlanName</div>
            <p class="mb-0 text-muted">
                @(Model.ViewModel.AdminTopPlanCount > 0
                    ? $"{Model.ViewModel.AdminTopPlanCount} lượt mua trong khoảng đang xem."
                    : "Chưa có giao dịch thành công nào.")
            </p>
        </article>
    </div>

    <div class="surface-card mb-5 admin-chart-panel">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
            <div>
                <div class="stat-label mb-2">Biểu đồ mua gói</div>
                <h3 class="h4 mb-0">Gói nào được mua nhiều nhất</h3>
            </div>
            <span class="status-chip info">Giá trị trung bình @Model.ViewModel.AdminAverageOrderValue.ToString("N0") đ</span>
        </div>

        @if (!Model.ViewModel.AdminPlanReports.Any() || Model.ViewModel.AdminPlanReports.All(plan => plan.PurchaseCount == 0))
        {
            <div class="alert alert-info mb-0">Chưa có giao dịch thành công nào để hiển thị biểu đồ.</div>
        }
        else
        {
            <div class="admin-column-chart">
                @foreach (var plan in Model.ViewModel.AdminPlanReports)
                {
                    <div class="admin-column-item">
                        <div class="admin-column-meta">
                            <strong>@plan.PurchaseCount</strong>
                            <span>lượt mua</span>
                        </div>
                        <div class="admin-column-track" aria-hidden="true">
                            <div class="admin-column-fill" style="height:@Math.Max(plan.PurchaseSharePercent, 8)%"></div>
                        </div>
                        <div class="admin-column-label">@plan.Name</div>
                        <div class="admin-column-subtitle">@plan.Revenue.ToString("N0") đ</div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="surface-card p-0 overflow-hidden">
        <div class="p-4 pb-0">
            <div class="stat-label mb-2">Bảng chi tiết</div>
            <h3 class="h4 mb-0">Doanh thu theo từng gói</h3>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Gói học</th>
                        <th>Giá</th>
                        <th>Thời hạn</th>
                        <th>Lượt mua</th>
                        <th>Tỷ trọng</th>
                        <th>Doanh thu</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var plan in Model.ViewModel.AdminPlanReports)
                    {
                        <tr>
                            <td>
                                <strong>@plan.Name</strong><br />
                                <small class="text-muted">@(string.IsNullOrWhiteSpace(plan.Description) ? "-" : plan.Description)</small>
                            </td>
                            <td>@plan.Price.ToString("N0") đ</td>
                            <td>@plan.DurationDays ngày</td>
                            <td>@plan.PurchaseCount</td>
                            <td>@plan.PurchaseSharePercent%</td>
                            <td>@plan.Revenue.ToString("N0") đ</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    var ticketsPagination = Model.TicketsPagination.ToViewModel(
        "/Subscription/Index",
        "pageNumber",
        "giao dịch",
        new Dictionary<string, object?> { ["quotaPage"] = Model.QuotaPage },
        fragment: "subscription-transactions");
    var quotasPagination = Model.QuotasPagination.ToViewModel(
        "/Subscription/Index",
        "quotaPage",
        "môn học",
        new Dictionary<string, object?> { ["pageNumber"] = Model.PageNumber },
        "subject-quotas");

    <section class="page-hero mb-4">
        <div class="hero-badge mb-3">Sinh viên</div>
        <h1 class="page-title">Mua gói Plus cho sinh viên</h1>
        <p class="page-subtitle mb-0">
            Xem gói hiện tại, hạn mức còn lại theo môn học, thời điểm đặt lại và nâng cấp Plus bằng cổng thanh toán MoMo.
        </p>
    </section>

    <div class="subscription-summary-grid mb-4">
        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Gói hiện tại</div>
            <div class="subscription-summary-value">@Model.ViewModel.CurrentPlanName</div>
            <p class="mb-0 text-muted">
                @if (!Model.ViewModel.IsPlus)
                {
                    <span>Gói miễn phí giới hạn @Model.ViewModel.FreeQuestionLimit câu mỗi môn trong @Model.ViewModel.FreeQuotaWindowHours giờ.</span>
                }
            </p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Số lần hỏi còn lại</div>
            <div class="subscription-summary-value">
                @(Model.ViewModel.IsPlus ? "Không giới hạn" : Model.ViewModel.TotalQuestionsRemaining.ToString())
            </div>
            <p class="mb-0 text-muted">
                @if (Model.ViewModel.IsPlus)
                {
                    <span>Gói Plus bỏ giới hạn số câu hỏi của sinh viên.</span>
                }
                else
                {
                    <span>Đây là tổng số lần hỏi còn lại của bạn trong chu kỳ hiện tại.</span>
                }
            </p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Đặt lại hoặc hết hạn</div>
            <div class="subscription-summary-value">
                @(nextResetAt.HasValue ? nextResetAt.Value.ToLocalTime().ToString("dd/MM HH:mm") : "-")
            </div>
            <p class="mb-0 text-muted">
                @if (Model.ViewModel.IsPlus && Model.ViewModel.ActiveSubscription is not null)
                {
                    <span>Đây là mốc hết hạn của gói Plus hiện tại.</span>
                }
                else
                {
                    <span>Hạn mức miễn phí được đặt lại sau mỗi @Model.ViewModel.FreeQuotaWindowHours giờ.</span>
                }
            </p>
        </article>
    </div>

    <div id="subject-quotas" class="surface-card mb-5">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2 mb-3">
            <div>
                <div class="stat-label mb-2">Hạn mức miễn phí</div>
                <h3 class="h5 mb-0">Hạn mức hiện tại theo từng môn học</h3>
            </div>
            <span class="small text-muted">
                @(nextResetAt.HasValue
                    ? (Model.ViewModel.IsPlus
                        ? $"Gói Plus hết hạn lúc {nextResetAt.Value.ToLocalTime():dd/MM/yyyy HH:mm}"
                        : $"Chu kỳ hiện tại kết thúc lúc {nextResetAt.Value.ToLocalTime():dd/MM/yyyy HH:mm}")
                    : $"Mỗi chu kỳ được đặt lại sau {Model.ViewModel.FreeQuotaWindowHours} giờ")
            </span>
        </div>

        @if (!Model.ViewModel.SubjectQuotas.Any())
        {
            <div class="alert alert-info mb-0">Chưa có môn học nào sẵn sàng cho Chat AI.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Môn học</th>
                            <th>Gói</th>
                            <th>Đã dùng</th>
                            <th>Còn lại</th>
                            <th>Đặt lại lúc</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var quota in Model.ViewModel.SubjectQuotas.OrderBy(q => q.SubjectCode).ThenBy(q => q.SubjectName))
                        {
                            <tr>
                                <td>
                                    <strong>@quota.SubjectCode</strong><br />
                                    <small class="text-muted">@quota.SubjectName</small>
                                </td>
                                <td>
                                    @if (quota.IsPlus)
                                    {
                                        <span class="status-chip bg-success">Plus</span>
                                    }
                                    else if (quota.IsAllowed)
                                    {
                                        <span class="status-chip bg-info text-dark">Free</span>
                                    }
                                    else
                                    {
                                        <span class="status-chip bg-warning text-dark">Hết hạn mức</span>
                                    }
                                </td>
                                <td>@(quota.IsPlus ? "-" : $"{quota.QuestionsUsed}/{quota.QuestionLimit}")</td>
                                <td>@(quota.IsPlus ? "Không giới hạn" : quota.QuestionsRemaining.ToString())</td>
                                <td>@(quota.IsPlus ? "-" : quota.WindowEndAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <partial name="_Pagination" model="quotasPagination" />
        }
    </div>

    @if (!Model.ViewModel.IsPlus)
    {
        <div class="row g-4 mb-5">
            @if (!Model.ViewModel.Plans.Any())
            {
                <div class="col-12">
                    <div class="alert alert-warning mb-0">Chưa có gói Plus nào được cấu hình.</div>
                </div>
            }
            else
            {
                @foreach (var plan in Model.ViewModel.Plans)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="surface-card h-100 plan-purchase-card">
                            <div class="d-flex flex-column h-100">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <div class="stat-label mb-2">Gói Plus</div>
                                        <h5 class="card-title mb-1">@plan.Name</h5>
                                        <p class="card-text text-muted mb-0">@plan.Description</p>
                                    </div>
                                    <span class="plan-duration-pill">@plan.DurationDays ngày</span>
                                </div>

                                <div class="plan-price mb-3">@plan.Price.ToString("N0") đ</div>

                                <ul class="plan-benefits">
                                    <li>Mở khóa hỏi đáp không giới hạn trong thời gian sử dụng gói.</li>
                                    <li>Kích hoạt tự động ngay sau khi MoMo xác nhận thanh toán.</li>
                                    <li>Có thể gia hạn nối tiếp khi sinh viên đang sử dụng Plus.</li>
                                </ul>

                                <form asp-page="/MoMoPayment/Checkout" asp-route-planId="@plan.Id" method="post" class="mt-auto">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-primary w-100 plan-buy-button">
                                        Nâng cấp Plus bằng MoMo
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }

    <div id="subscription-transactions">
        <h4>Lịch sử giao dịch MoMo</h4>
        @if (!Model.ViewModel.Tickets.Any())
        {
            <div class="alert alert-info">Chưa có giao dịch MoMo nào.</div>
        }
        else
        {
            <div class="surface-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Gói học</th>
                                <th>Số tiền</th>
                                <th>Mã đơn</th>
                                <th>Trạng thái</th>
                                <th>Ghi chú</th>
                                <th>Ngày tạo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in Model.ViewModel.Tickets)
                            {
                                <tr>
                                    <td>@ticket.Id</td>
                                    <td>@ticket.PlanName</td>
                                    <td>@ticket.Amount.ToString("N0") đ</td>
                                    <td>@(string.IsNullOrWhiteSpace(ticket.TransferReference) ? "-" : ticket.TransferReference)</td>
                                    <td><span class="status-chip @StatusBadge(ticket.Status)">@StatusLabel(ticket.Status)</span></td>
                                    <td>@(string.IsNullOrWhiteSpace(ticket.AdminNote) ? "-" : ticket.AdminNote)</td>
                                    <td>@(ticket.CreatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <partial name="_Pagination" model="ticketsPagination" />
            </div>
        }
    </div>
}
