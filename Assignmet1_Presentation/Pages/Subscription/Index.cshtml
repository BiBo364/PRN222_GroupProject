@page "/Subscription/Index"
@model Assignmet1_Presentation.Pages.Subscription.IndexModel
@using Assignmet1_Presentation.Constants
@{
    ViewData["Title"] = "Goi Plus";
    var nextResetAt = Model.ViewModel.NextResetAt;
    string StatusLabel(string status) => status switch
    {
        PaymentStatuses.MomoPending => "Dang cho MoMo",
        PaymentStatuses.Approved => "Thanh cong",
        PaymentStatuses.Rejected => "That bai",
        _ => "Dang xu ly"
    };
    string StatusBadge(string status) => status switch
    {
        PaymentStatuses.MomoPending => "bg-info text-dark",
        PaymentStatuses.Approved => "bg-success",
        PaymentStatuses.Rejected => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

@if (Model.ViewModel.IsAdminView)
{
    <section class="page-hero mb-4">
        <div class="hero-badge mb-3">Admin subscription</div>
        <h1 class="page-title">Quan ly goi hoc va doanh thu</h1>
        <p class="page-subtitle mb-0">
            Xem tat ca goi dang ky hien co, tong doanh thu, goi duoc mua nhieu nhat va bao cao doanh thu theo thoi gian.
        </p>
    </section>

    <div class="surface-card mb-5">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
            <div>
                <div class="stat-label mb-2">Danh sach goi</div>
                <h3 class="h4 mb-0">Tat ca goi hoc hien tai</h3>
            </div>
            <span class="status-chip primary">@Model.ViewModel.Plans.Count goi</span>
        </div>

        @if (!Model.ViewModel.AdminPlanReports.Any())
        {
            <div class="alert alert-warning mb-0">Chua co goi hoc nao duoc cau hinh.</div>
        }
        else
        {
            <div class="admin-plan-card-grid">
                @foreach (var plan in Model.ViewModel.AdminPlanReports)
                {
                    <article class="surface-card plan-purchase-card admin-plan-showcase-card">
                        <div class="d-flex flex-column h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <div class="stat-label mb-2 admin-plan-kicker">Goi Plus</div>
                                    <h4 class="card-title mb-1 admin-plan-title">@plan.Name</h4>
                                    <p class="card-text admin-plan-description mb-0">@(string.IsNullOrWhiteSpace(plan.Description) ? "Khong co mo ta." : plan.Description)</p>
                                </div>
                                <span class="plan-duration-pill">@plan.DurationDays ngay</span>
                            </div>

                            <div class="plan-price mb-3 admin-plan-price">@plan.Price.ToString("N0") d</div>

                            <ul class="plan-benefits admin-plan-benefits">
                                <li><strong>@plan.PurchaseCount luot mua thanh cong</strong></li>
                                <li><strong>@plan.Revenue.ToString("N0") d doanh thu</strong></li>
                                <li><strong>Chiem @plan.PurchaseSharePercent%</strong> tong don thanh cong.</li>
                            </ul>
                        </div>
                    </article>
                }
            </div>
        }
    </div>

    <div class="surface-card mb-4 admin-filter-card">
        <form method="get" asp-page="/Subscription/Index" class="row g-3 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label" for="fromDate">Tu ngay</label>
                <input class="form-control" id="fromDate" name="fromDate" type="date" value="@(Model.ViewModel.FilterFromDate?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" for="toDate">Den ngay</label>
                <input class="form-control" id="toDate" name="toDate" type="date" value="@(Model.ViewModel.FilterToDate?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-12 col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">Loc bao cao</button>
                <a class="btn btn-outline-light flex-fill" asp-page="/Subscription/Index">Xem toan bo</a>
            </div>
        </form>
        <p class="small text-muted mb-0 mt-3">
            @(Model.ViewModel.FilterFromDate.HasValue || Model.ViewModel.FilterToDate.HasValue
                ? $"Dang xem doanh thu trong khoang {(Model.ViewModel.FilterFromDate?.ToString("dd/MM/yyyy") ?? "tat ca")} - {(Model.ViewModel.FilterToDate?.ToString("dd/MM/yyyy") ?? "hien tai")}."
                : "Chua chon thoi gian, he thong dang hien thi toan bo doanh thu tu truoc den hien tai.")
        </p>
    </div>

    <div class="subscription-summary-grid admin-summary-grid mb-4">
        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Tong goi dang co</div>
            <div class="subscription-summary-value">@Model.ViewModel.Plans.Count</div>
            <p class="mb-0 text-muted">Tong so goi hien website dang cau hinh cho sinh vien mua.</p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Tong doanh thu</div>
            <div class="subscription-summary-value">@Model.ViewModel.AdminTotalRevenue.ToString("N0") d</div>
            <p class="mb-0 text-muted">Chi tinh giao dich thanh cong trong khoang dang loc.</p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Don thanh cong</div>
            <div class="subscription-summary-value">@Model.ViewModel.AdminSuccessfulOrders</div>
            <p class="mb-0 text-muted">Tong so don MoMo da thanh toan va kich hoat goi thanh cong.</p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Goi mua nhieu nhat</div>
            <div class="subscription-summary-value">@Model.ViewModel.AdminTopPlanName</div>
            <p class="mb-0 text-muted">
                @(Model.ViewModel.AdminTopPlanCount > 0
                    ? $"{Model.ViewModel.AdminTopPlanCount} luot mua trong khoang dang xem."
                    : "Chua co giao dich thanh cong nao.")
            </p>
        </article>
    </div>

    <div class="surface-card mb-5 admin-chart-panel">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
            <div>
                <div class="stat-label mb-2">Bieu do mua goi</div>
                <h3 class="h4 mb-0">Goi nao duoc mua nhieu nhat</h3>
            </div>
            <span class="status-chip info">Gia tri TB @Model.ViewModel.AdminAverageOrderValue.ToString("N0") d</span>
        </div>

        @if (!Model.ViewModel.AdminPlanReports.Any() || Model.ViewModel.AdminPlanReports.All(plan => plan.PurchaseCount == 0))
        {
            <div class="alert alert-info mb-0">Chua co giao dich thanh cong nao de hien thi bieu do.</div>
        }
        else
        {
            <div class="admin-column-chart">
                @foreach (var plan in Model.ViewModel.AdminPlanReports)
                {
                    <div class="admin-column-item">
                        <div class="admin-column-meta">
                            <strong>@plan.PurchaseCount</strong>
                            <span>luot mua</span>
                        </div>
                        <div class="admin-column-track" aria-hidden="true">
                            <div class="admin-column-fill" style="height:@Math.Max(plan.PurchaseSharePercent, 8)m%"></div>
                        </div>
                        <div class="admin-column-label">@plan.Name</div>
                        <div class="admin-column-subtitle">@plan.Revenue.ToString("N0") d</div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="surface-card p-0 overflow-hidden">
        <div class="p-4 pb-0">
            <div class="stat-label mb-2">Bang chi tiet</div>
            <h3 class="h4 mb-0">Doanh thu theo tung goi</h3>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Goi hoc</th>
                        <th>Gia</th>
                        <th>Thoi han</th>
                        <th>Luot mua</th>
                        <th>Ty trong</th>
                        <th>Doanh thu</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var plan in Model.ViewModel.AdminPlanReports)
                    {
                        <tr>
                            <td>
                                <strong>@plan.Name</strong><br />
                                <small class="text-muted">@(string.IsNullOrWhiteSpace(plan.Description) ? "-" : plan.Description)</small>
                            </td>
                            <td>@plan.Price.ToString("N0") d</td>
                            <td>@plan.DurationDays ngay</td>
                            <td>@plan.PurchaseCount</td>
                            <td>@plan.PurchaseSharePercent%</td>
                            <td>@plan.Revenue.ToString("N0") d</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <section class="page-hero mb-4">
        <div class="hero-badge mb-3">Student subscription</div>
        <h1 class="page-title">Mua goi Plus cho sinh vien</h1>
        <p class="page-subtitle mb-0">
            Xem goi hien tai, quota con lai theo mon hoc, thoi diem reset va nang cap Plus ngay bang cong thanh toan MoMo.
        </p>
    </section>

    <div class="subscription-summary-grid mb-4">
        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Goi hien tai</div>
            <div class="subscription-summary-value">@Model.ViewModel.CurrentPlanName</div>
            <p class="mb-0 text-muted">
                @if (!Model.ViewModel.IsPlus)
                {
                    <span>Free plan gioi han @Model.ViewModel.FreeQuestionLimit cau moi mon trong @Model.ViewModel.FreeQuotaWindowHours gio.</span>
                }
            </p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">So lan hoi con lai</div>
            <div class="subscription-summary-value">
                @(Model.ViewModel.IsPlus ? "Unlimited" : Model.ViewModel.TotalQuestionsRemaining.ToString())
            </div>
            <p class="mb-0 text-muted">
                @if (Model.ViewModel.IsPlus)
                {
                    <span>Goi Plus bo gioi han so cau hoi cua student.</span>
                }
                else
                {
                    <span>Day la tong so lan hoi con lai cua ban trong cua so hien tai.</span>
                }
            </p>
        </article>

        <article class="surface-card subscription-summary-card">
            <div class="stat-label mb-2">Reset / het han</div>
            <div class="subscription-summary-value">
                @(nextResetAt.HasValue ? nextResetAt.Value.ToLocalTime().ToString("dd/MM HH:mm") : "-")
            </div>
            <p class="mb-0 text-muted">
                @if (Model.ViewModel.IsPlus && Model.ViewModel.ActiveSubscription is not null)
                {
                    <span>Day la moc het han goi Plus hien tai.</span>
                }
                else
                {
                    <span>Quota Free duoc reset dong loat theo cua so @Model.ViewModel.FreeQuotaWindowHours gio.</span>
                }
            </p>
        </article>
    </div>

    <div class="surface-card mb-5">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2 mb-3">
            <div>
                <div class="stat-label mb-2">Free quota</div>
                <h3 class="h5 mb-0">Quota hien tai theo tung mon hoc</h3>
            </div>
            <span class="small text-muted">
                @(nextResetAt.HasValue
                    ? (Model.ViewModel.IsPlus
                        ? $"Goi Plus het han luc {nextResetAt.Value.ToLocalTime():dd/MM/yyyy HH:mm}"
                        : $"Cua so hien tai ket thuc luc {nextResetAt.Value.ToLocalTime():dd/MM/yyyy HH:mm}")
                    : $"Moi cua so reset sau {Model.ViewModel.FreeQuotaWindowHours} gio")
            </span>
        </div>

        @if (!Model.ViewModel.SubjectQuotas.Any())
        {
            <div class="alert alert-info mb-0">Chua co mon hoc nao san sang cho chat.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Mon hoc</th>
                            <th>Plan</th>
                            <th>Da dung</th>
                            <th>Con lai</th>
                            <th>Reset luc</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var quota in Model.ViewModel.SubjectQuotas.OrderBy(q => q.SubjectCode).ThenBy(q => q.SubjectName))
                        {
                            <tr>
                                <td>
                                    <strong>@quota.SubjectCode</strong><br />
                                    <small class="text-muted">@quota.SubjectName</small>
                                </td>
                                <td>
                                    @if (quota.IsPlus)
                                    {
                                        <span class="status-chip bg-success">Plus</span>
                                    }
                                    else if (quota.IsAllowed)
                                    {
                                        <span class="status-chip bg-info text-dark">Free</span>
                                    }
                                    else
                                    {
                                        <span class="status-chip bg-warning text-dark">Het quota</span>
                                    }
                                </td>
                                <td>@(quota.IsPlus ? "-" : $"{quota.QuestionsUsed}/{quota.QuestionLimit}")</td>
                                <td>@(quota.IsPlus ? "Unlimited" : quota.QuestionsRemaining.ToString())</td>
                                <td>@(quota.IsPlus ? "-" : quota.WindowEndAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @if (!Model.ViewModel.IsPlus)
    {
        <div class="row g-4 mb-5">
            @if (!Model.ViewModel.Plans.Any())
            {
                <div class="col-12">
                    <div class="alert alert-warning mb-0">Chua co goi Plus nao duoc cau hinh.</div>
                </div>
            }
            else
            {
                @foreach (var plan in Model.ViewModel.Plans)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="surface-card h-100 plan-purchase-card">
                            <div class="d-flex flex-column h-100">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <div class="stat-label mb-2">Goi Plus</div>
                                        <h5 class="card-title mb-1">@plan.Name</h5>
                                        <p class="card-text text-muted mb-0">@plan.Description</p>
                                    </div>
                                    <span class="plan-duration-pill">@plan.DurationDays ngay</span>
                                </div>

                                <div class="plan-price mb-3">@plan.Price.ToString("N0") d</div>

                                <ul class="plan-benefits">
                                    <li>Mo khoa hoi dap khong gioi han trong thoi gian goi.</li>
                                    <li>Kich hoat tu dong ngay sau khi MoMo xac nhan thanh toan.</li>
                                    <li>Co the gia han tiep noi neu student da dang dung Plus.</li>
                                </ul>

                                <form asp-page="/MoMoPayment/Checkout" asp-route-planId="@plan.Id" method="post" class="mt-auto">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-primary w-100 plan-buy-button">
                                        Nang cap len Plus bang MoMo
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }

    <div>
        <h4>Lich su giao dich MoMo</h4>
        @if (!Model.ViewModel.Tickets.Any())
        {
            <div class="alert alert-info">Chua co giao dich MoMo nao.</div>
        }
        else
        {
            <div class="surface-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Goi</th>
                                <th>So tien</th>
                                <th>Ma don</th>
                                <th>Trang thai</th>
                                <th>Ghi chu</th>
                                <th>Ngay tao</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ticket in Model.ViewModel.Tickets)
                            {
                                <tr>
                                    <td>@ticket.Id</td>
                                    <td>@ticket.PlanName</td>
                                    <td>@ticket.Amount.ToString("N0") d</td>
                                    <td>@(string.IsNullOrWhiteSpace(ticket.TransferReference) ? "-" : ticket.TransferReference)</td>
                                    <td><span class="status-chip @StatusBadge(ticket.Status)">@StatusLabel(ticket.Status)</span></td>
                                    <td>@(string.IsNullOrWhiteSpace(ticket.AdminNote) ? "-" : ticket.AdminNote)</td>
                                    <td>@(ticket.CreatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}
