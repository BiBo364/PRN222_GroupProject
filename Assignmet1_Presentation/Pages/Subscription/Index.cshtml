@page "/Subscription/Index"
@model Assignmet1_Presentation.Pages.Subscription.IndexModel
@using Assignmet1_Presentation.Constants
@{
    ViewData["Title"] = "Goi hoc";
    var nextResetAt = Model.ViewModel.SubjectQuotas.FirstOrDefault(quota => !quota.IsPlus)?.WindowEndAt;
    string StatusLabel(string status) => status switch
    {
        PaymentStatuses.MomoPending => "Dang cho MoMo",
        PaymentStatuses.Approved => "Thanh cong",
        PaymentStatuses.Rejected => "That bai",
        _ => "Dang xu ly"
    };
    string StatusBadge(string status) => status switch
    {
        PaymentStatuses.MomoPending => "bg-info text-dark",
        PaymentStatuses.Approved => "bg-success",
        PaymentStatuses.Rejected => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

<section class="page-hero mb-4">
    <div class="hero-badge mb-3">Subscription</div>
    <h1 class="page-title">Free va Plus</h1>
    <p class="page-subtitle mb-0">Moi sinh vien deu co the chat bang Free plan. Nang cap Plus qua MoMo de bo gioi han cau hoi.</p>
</section>

@if (TempData["Info"] is string info)
{
    <div class="alert alert-info">@info</div>
}

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="surface-card h-100">
            <div class="stat-label mb-2">Current plan</div>
            <h3 class="h5 mb-3">@Model.ViewModel.CurrentPlanName</h3>
            @if (Model.ViewModel.IsPlus && Model.ViewModel.ActiveSubscription is not null)
            {
                <div class="alert alert-success mb-0">
                    <strong>Plus dang hoat dong.</strong><br />
                    Goi hien tai: @Model.ViewModel.ActiveSubscription.PlanName<br />
                    Het han: <strong>@Model.ViewModel.ActiveSubscription.EndAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</strong>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    <strong>Free plan dang hoat dong.</strong><br />
                    Ban duoc hoi toi da <strong>@Model.ViewModel.FreeQuestionLimit</strong> cau cho moi mon trong
                    <strong>@Model.ViewModel.FreeQuotaWindowHours gio</strong>.
                </div>
            }
        </div>
    </div>
    <div class="col-lg-6">
        <div class="surface-card h-100">
            <div class="stat-label mb-2">Upgrade</div>
            <h3 class="h5 mb-3">Thanh toan chi qua MoMo</h3>
            <p class="mb-2">He thong da bo luong ticket chuyen khoan thu cong. Sau khi MoMo xac nhan thanh toan, tai khoan se tu dong kich hoat Plus.</p>
            <p class="small text-muted mb-0">Neu ban dang o Free plan, khi het quota theo mon hoc thi hay doi reset hoac nang cap len Plus.</p>
        </div>
    </div>
</div>

<div class="surface-card mb-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2 mb-3">
        <div>
            <div class="stat-label mb-2">Free quota</div>
            <h3 class="h5 mb-0">So cau hoi con lai theo tung mon</h3>
        </div>
        <span class="small text-muted">
            @(nextResetAt.HasValue
                ? $"Cua so hien tai ket thuc luc {nextResetAt.Value.ToLocalTime():dd/MM/yyyy HH:mm}"
                : $"Moi cua so reset sau {Model.ViewModel.FreeQuotaWindowHours} gio")
        </span>
    </div>

    @if (!Model.ViewModel.SubjectQuotas.Any())
    {
        <div class="alert alert-info mb-0">Chua co mon hoc nao san sang cho chat.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Mon hoc</th>
                        <th>Plan</th>
                        <th>Da dung</th>
                        <th>Con lai</th>
                        <th>Reset luc</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var quota in Model.ViewModel.SubjectQuotas.OrderBy(q => q.SubjectCode).ThenBy(q => q.SubjectName))
                    {
                        <tr>
                            <td>
                                <strong>@quota.SubjectCode</strong><br />
                                <small class="text-muted">@quota.SubjectName</small>
                            </td>
                            <td>
                                @if (quota.IsPlus)
                                {
                                    <span class="status-chip bg-success">Plus</span>
                                }
                                else if (quota.IsAllowed)
                                {
                                    <span class="status-chip bg-info text-dark">Free</span>
                                }
                                else
                                {
                                    <span class="status-chip bg-warning text-dark">Het quota</span>
                                }
                            </td>
                            <td>@(quota.IsPlus ? "-" : $"{quota.QuestionsUsed}/{quota.QuestionLimit}")</td>
                            <td>@(quota.IsPlus ? "Unlimited" : quota.QuestionsRemaining.ToString())</td>
                            <td>@(quota.IsPlus ? "-" : quota.WindowEndAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="row g-4 mb-5">
    @if (!Model.ViewModel.Plans.Any())
    {
        <div class="col-12">
            <div class="alert alert-warning mb-0">Chua co goi Plus nao duoc cau hinh.</div>
        </div>
    }
    else
    {
        @foreach (var plan in Model.ViewModel.Plans)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="stat-label mb-2">Plus option</div>
                        <h5 class="card-title">@plan.Name</h5>
                        <p class="card-text text-muted">@plan.Description</p>
                        <p class="fs-4 fw-bold text-primary mb-1">@plan.Price.ToString("N0") d</p>
                        <p class="small text-muted">@plan.DurationDays ngay Plus</p>
                        <form asp-page="/MoMoPayment/Checkout" asp-route-planId="@plan.Id" method="post" class="mt-auto">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary w-100">
                                @(Model.ViewModel.IsPlus ? "Gia han Plus bang MoMo" : "Nang cap len Plus bang MoMo")
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
</div>

<div>
    <h4>Lich su giao dich</h4>
    @if (!Model.ViewModel.Tickets.Any())
    {
        <div class="alert alert-info">Chua co giao dich MoMo nao.</div>
    }
    else
    {
        <div class="surface-card p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Goi</th>
                            <th>So tien</th>
                            <th>Ma don</th>
                            <th>Trang thai</th>
                            <th>Ghi chu</th>
                            <th>Ngay tao</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in Model.ViewModel.Tickets)
                        {
                            <tr>
                                <td>@ticket.Id</td>
                                <td>@ticket.PlanName</td>
                                <td>@ticket.Amount.ToString("N0") d</td>
                                <td>@(string.IsNullOrWhiteSpace(ticket.TransferReference) ? "-" : ticket.TransferReference)</td>
                                <td><span class="status-chip @StatusBadge(ticket.Status)">@StatusLabel(ticket.Status)</span></td>
                                <td>@(string.IsNullOrWhiteSpace(ticket.AdminNote) ? "-" : ticket.AdminNote)</td>
                                <td>@(ticket.CreatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
