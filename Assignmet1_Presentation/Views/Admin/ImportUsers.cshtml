@model ImportUsersViewModel
@using Assignment1_Service.Models
@{
    ViewData["Title"] = "Import nguoi dung";
}

<div class="d-flex flex-column gap-4">
    <div class="page-hero d-flex flex-column flex-md-row align-items-md-start justify-content-between gap-3">
        <div>
            <div class="hero-badge mb-2">Nhap du lieu hang loat</div>
            <h1 class="page-title mb-1">Import nguoi dung</h1>
            <p class="page-subtitle mb-0">
                Upload file <strong>.xlsx, .csv, .json, .txt</strong>. He thong se tao tai khoan voi
                mat khau mac dinh <code>1234567</code> va se gui email thong bao neu SMTP da duoc cau hinh.
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary flex-shrink-0">Quay lai danh sach</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="surface-card h-100">
                <h2 class="h5 fw-semibold mb-4">Tai len danh sach</h2>

                <form asp-action="ImportUsers" method="post" enctype="multipart/form-data" id="importForm">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger mb-4">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }

                    <div class="mb-4">
                        <label asp-for="RoleId" class="form-label fw-semibold"></label>
                        <select asp-for="RoleId" class="form-select form-select-lg">
                            <option value="2">Giang vien</option>
                            <option value="4" selected>Sinh vien</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="SubjectId" class="form-label fw-semibold"></label>
                        <select asp-for="SubjectId" class="form-select form-select-lg">
                            <option value="">Khong gan mon hoc</option>
                            @foreach (var s in Model.SubjectOptions)
                            {
                                var isTakenByTeacher = Model.TeacherBySubjectId.TryGetValue(s.Id, out var assignedTeacher);
                                <option value="@s.Id">
                                    @s.Code - @s.Name@(isTakenByTeacher ? $" (da co GV: {assignedTeacher})" : "")
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="File" class="form-label fw-semibold"></label>
                        <input type="file" asp-for="File" accept=".xlsx,.xls,.csv,.json,.txt" class="form-control" />
                        <span asp-validation-for="File" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100" id="submitBtn">Bat dau Import</button>
                </form>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="surface-card h-100">
                <h2 class="h5 fw-semibold mb-4">Huong dan</h2>
                <div class="d-flex flex-column gap-3">
                    <div class="mini-panel">
                        <div class="fw-semibold small">Dinh dang file</div>
                        <div class="text-muted small">Cot 1: FullName, cot 2: Email hop le, cot 3: Username (tuy chon).</div>
                    </div>
                    <div class="mini-panel">
                        <div class="fw-semibold small">Mat khau mac dinh</div>
                        <div class="text-muted small">Tai khoan moi se duoc tao voi mat khau <strong>1234567</strong>.</div>
                    </div>
                    <div class="mini-panel">
                        <div class="fw-semibold small">Doi mat khau lan dau</div>
                        <div class="text-muted small">Nguoi dung dang nhap bang mat khau mac dinh se bi dieu huong sang man doi mat khau.</div>
                    </div>
                    <div class="mini-panel">
                        <div class="fw-semibold small">Email thong bao</div>
                        <div class="text-muted small">Neu SMTP da cau hinh, he thong gui email chua username va mat khau tam toi tung user moi tao, khong gioi han duoi email.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Result is { } result)
    {
        <div class="surface-card mt-4">
            <h2 class="h5 fw-semibold mb-4">Ket qua import</h2>

            <div class="row g-3 mb-4">
                <div class="col-6 col-md-2">
                    <div class="stat-card text-center">
                        <div class="stat-value">@result.TotalRows</div>
                        <div class="stat-label">Tong dong</div>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <div class="stat-card text-center">
                        <div class="stat-value">@result.CreatedCount</div>
                        <div class="stat-label">Tao OK</div>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <div class="stat-card text-center">
                        <div class="stat-value">@result.SkippedDuplicateCount</div>
                        <div class="stat-label">Trung lap</div>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <div class="stat-card text-center">
                        <div class="stat-value">@result.ErrorCount</div>
                        <div class="stat-label">Loi</div>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <div class="stat-card text-center">
                        <div class="stat-value">@result.NotificationSentCount</div>
                        <div class="stat-label">Mail OK</div>
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <div class="stat-card text-center">
                        <div class="stat-value">@result.NotificationFailedCount</div>
                        <div class="stat-label">Mail loi</div>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Dong</th>
                            <th>Ho ten</th>
                            <th>Email</th>
                            <th>Username</th>
                            <th>Trang thai</th>
                            <th>Email TB</th>
                            <th>Ghi chu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in result.Rows)
                        {
                            <tr>
                                <td>@row.RowNumber</td>
                                <td>@(row.FullName ?? "-")</td>
                                <td>@(row.Email ?? "-")</td>
                                <td>@(row.Username ?? "-")</td>
                                <td>@row.StatusLabel</td>
                                <td>
                                    @if (row.NotificationSent is true)
                                    {
                                        <span>Da gui</span>
                                    }
                                    else if (row.NotificationSent is false)
                                    {
                                        <span>Chua gui</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>
                                    @row.Message
                                    @if (!string.IsNullOrWhiteSpace(row.NotificationMessage))
                                    {
                                        <div class="text-muted small">@row.NotificationMessage</div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    document.getElementById('importForm').addEventListener('submit', function () {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = 'Dang xu ly...';
    });
</script>
}
