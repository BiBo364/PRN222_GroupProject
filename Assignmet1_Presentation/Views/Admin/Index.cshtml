@model UserListViewModel
@using Assignmet1_Presentation.Models
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="d-flex flex-column gap-4">

    @* ── HERO ──────────────────────────────────────────────── *@
    <div class="page-hero d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div>
            <div class="hero-badge mb-2">⚙️ Quản trị hệ thống</div>
            <h1 class="page-title mb-1">Quản lý người dùng</h1>
            <p class="page-subtitle">Xem, phân công môn học và quản lý trạng thái tài khoản toàn hệ thống.</p>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
            <a asp-action="ImportStudents" class="btn btn-primary">
                📥 Import từ Excel
            </a>
        </div>
    </div>

    @* ── ALERT MESSAGES ───────────────────────────────────── *@
    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-0" role="alert">
            <span>✅</span> @success
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-0" role="alert">
            <span>❌</span> @error
        </div>
    }

    @* ── STATS ROW ─────────────────────────────────────────── *@
    @{
        var totalUsers    = Model.Users.Count;
        var activeUsers   = Model.Users.Count(u => u.IsActive);
        var studentCount  = Model.Users.Count(u => u.RoleId == 4);
        var unassigned    = Model.Users.Count(u => u.RoleId == 4 && u.SubjectId == null);
    }
    <div class="row g-3">
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value text-info">@totalUsers</div>
                <div class="stat-label">Tổng người dùng</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value" style="color:#34d399">@activeUsers</div>
                <div class="stat-label">Đang hoạt động</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value" style="color:#f6b73c">@studentCount</div>
                <div class="stat-label">Sinh viên</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card text-center">
                <div class="stat-value" style="color:#f87171">@unassigned</div>
                <div class="stat-label">Chưa có môn học</div>
            </div>
        </div>
    </div>

    @* ── FILTER / SEARCH ─────────────────────────────────── *@
    <div class="surface-card">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label text-muted small fw-semibold">🔍 Tìm kiếm</label>
                <input type="text" name="search" value="@Model.SearchTerm"
                       class="form-control" placeholder="Tên, email, username…" />
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small fw-semibold">👤 Vai trò</label>
                <select name="roleId" class="form-select">
                    <option value="">Tất cả vai trò</option>
                    <option value="1" selected="@(Model.FilterRoleId == 1)">SuperAdmin</option>
                    <option value="2" selected="@(Model.FilterRoleId == 2)">Admin</option>
                    <option value="3" selected="@(Model.FilterRoleId == 3)">Teacher</option>
                    <option value="4" selected="@(Model.FilterRoleId == 4)">Sinh viên</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label text-muted small fw-semibold">📚 Môn học</label>
                <select name="subjectId" class="form-select">
                    <option value="">Tất cả môn học</option>
                    @foreach (var s in Model.Subjects)
                    {
                        <option value="@s.Id" selected="@(Model.FilterSubjectId == s.Id)">@s.Code — @s.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">Lọc</button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Reset</a>
            </div>
        </form>
    </div>

    @* ── TABLE ────────────────────────────────────────────── *@
    <div class="surface-card p-0 overflow-hidden">
        <div class="px-4 py-3 d-flex align-items-center justify-content-between" style="border-bottom:1px solid rgba(255,255,255,.08)">
            <h2 class="h6 mb-0 fw-semibold">Danh sách người dùng (@Model.Users.Count)</h2>
        </div>

        @if (Model.Users.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <div style="font-size:3rem">👥</div>
                <p class="mt-2">Không tìm thấy người dùng nào phù hợp.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle" id="usersTable">
                    <thead>
                        <tr>
                            <th class="ps-4">Người dùng</th>
                            <th>Vai trò</th>
                            <th>Môn học</th>
                            <th>Trạng thái</th>
                            <th>Đăng nhập lần cuối</th>
                            <th class="pe-4 text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                @* Avatar + name + email *@
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="user-avatar" style="width:38px;height:38px;border-radius:50%;
                                            background:linear-gradient(135deg,#60a5fa,#2563eb);
                                            display:flex;align-items:center;justify-content:center;
                                            font-weight:700;font-size:.9rem;flex-shrink:0;">
                                            @(user.FullName?.Length > 0 ? user.FullName[0].ToString().ToUpper() : user.Username[0].ToString().ToUpper())
                                        </div>
                                        <div>
                                            <div class="fw-semibold" style="font-size:.9rem">@(user.FullName ?? user.Username)</div>
                                            <div class="text-muted" style="font-size:.78rem">@user.Email</div>
                                            <div style="font-size:.75rem;color:#64748b">@@user.Username</div>
                                        </div>
                                    </div>
                                </td>

                                @* Role badge *@
                                <td>
                                    @{
                                        var (roleColor, roleIcon) = user.RoleId switch {
                                            1 => ("#fbbf24", "👑"),
                                            2 => ("#f87171", "🛡️"),
                                            3 => ("#34d399", "📖"),
                                            _ => ("#60a5fa", "🎓")
                                        };
                                    }
                                    <span class="status-chip" style="border-color:@(roleColor)22;background:@(roleColor)18;color:@(roleColor)">
                                        @roleIcon @user.RoleLabel
                                    </span>
                                </td>

                                @* Subject assignment *@
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (user.SubjectId.HasValue)
                                        {
                                            <span class="status-chip" style="background:rgba(96,165,250,.1);border-color:rgba(96,165,250,.25);color:#93c5fd;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                                📚 @user.SubjectCode
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }

                                        @* Assign subject dropdown *@
                                        <div class="dropdown">
                                            <button class="btn btn-outline-secondary btn-sm py-0 px-2"
                                                    data-bs-toggle="dropdown" title="Phân công môn học"
                                                    style="font-size:.75rem;border-radius:.5rem">⋯</button>
                                            <ul class="dropdown-menu dropdown-menu-end" style="background:#0d172a;border:1px solid rgba(255,255,255,.1);min-width:220px">
                                                <li><h6 class="dropdown-header" style="color:#94a3b8">Phân công môn học</h6></li>
                                                <li>
                                                    <form asp-action="AssignSubject" method="post" class="px-3 pb-2">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="userId" value="@user.Id" />
                                                        <select name="subjectId" class="form-select form-select-sm mb-2" style="font-size:.82rem">
                                                            <option value="">— Bỏ môn học —</option>
                                                            @foreach (var s in Model.Subjects)
                                                            {
                                                                <option value="@s.Id" selected="@(user.SubjectId == s.Id)">@s.Code — @s.Name</option>
                                                            }
                                                        </select>
                                                        <button type="submit" class="btn btn-primary btn-sm w-100" style="font-size:.8rem;padding:.35rem">
                                                            Lưu phân công
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </td>

                                @* Active status *@
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="status-chip" style="background:rgba(52,211,153,.1);border-color:rgba(52,211,153,.25);color:#6ee7b7">
                                            ● Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-chip" style="background:rgba(248,113,113,.1);border-color:rgba(248,113,113,.25);color:#fca5a5">
                                            ○ Vô hiệu
                                        </span>
                                    }
                                </td>

                                @* Last login *@
                                <td>
                                    <span class="text-muted small">
                                        @(user.LastLoginAt.HasValue ? user.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa đăng nhập")
                                    </span>
                                </td>

                                @* Actions *@
                                <td class="pe-4 text-end">
                                    <form asp-action="ToggleStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit"
                                                class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                                                style="font-size:.78rem;padding:.3rem .7rem;border-radius:.5rem"
                                                onclick="return confirm('@(user.IsActive ? "Vô hiệu hoá" : "Kích hoạt") tài khoản @(user.FullName ?? user.Username)?')">
                                            @(user.IsActive ? "🔒 Vô hiệu" : "✅ Kích hoạt")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="px-4 py-3 d-flex align-items-center justify-content-between border-top" style="border-color:rgba(255,255,255,.08)!important">
                    <div class="text-muted small">
                        Hiển thị @(Model.Users.Count > 0 ? (Model.CurrentPage - 1) * Model.PageSize + 1 : 0) - @((Model.CurrentPage - 1) * Model.PageSize + Model.Users.Count) trong số @Model.TotalItems kết quả
                    </div>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link bg-transparent border-secondary text-light" 
                                   asp-action="Index" 
                                   asp-route-page="@(Model.CurrentPage - 1)"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-roleId="@Model.FilterRoleId"
                                   asp-route-subjectId="@Model.FilterSubjectId">« Trước</a>
                            </li>
                            
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                    <a class="page-link @(Model.CurrentPage == i ? "bg-primary border-primary text-white" : "bg-transparent border-secondary text-light")" 
                                       asp-action="Index" 
                                       asp-route-page="@i"
                                       asp-route-search="@Model.SearchTerm"
                                       asp-route-roleId="@Model.FilterRoleId"
                                       asp-route-subjectId="@Model.FilterSubjectId">@i</a>
                                </li>
                            }

                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link bg-transparent border-secondary text-light" 
                                   asp-action="Index" 
                                   asp-route-page="@(Model.CurrentPage + 1)"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-roleId="@Model.FilterRoleId"
                                   asp-route-subjectId="@Model.FilterSubjectId">Sau »</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>
