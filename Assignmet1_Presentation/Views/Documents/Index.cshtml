@model DocumentListViewModel
@{
    ViewData["Title"] = "Documents";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2>Indexed documents</h2>
        @if (Model.DemoSubject is not null)
        {
            <p class="text-muted mb-0">Subject: <strong>@Model.DemoSubject.Code</strong> — @Model.DemoSubject.Name</p>
        }
    </div>
    @if (Model.CanUpload)
    {
        <a class="btn btn-primary" asp-action="Upload">Upload document</a>
    }
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

@if (!Model.CanUpload && !Model.CanDelete)
{
    <div class="alert alert-info">View-only access. You can browse and open documents but cannot upload or delete.</div>
}

@if (!Model.Documents.Any())
{
    <div class="alert alert-info">No documents indexed yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>File name</th>
                    <th>Type</th>
                    <th>Chapter</th>
                    <th>Status</th>
                    <th>Chunks</th>
                    <th>Uploaded</th>
                    <th>Indexed</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model.Documents)
                {
                    <tr>
                        <td>@doc.OriginalName</td>
                        <td><span class="badge bg-secondary">@doc.FileType.ToUpper()</span></td>
                        <td>@(doc.ChapterNumber is null ? "—" : $"Ch.{doc.ChapterNumber}: {doc.ChapterTitle}")</td>
                        <td>
                            @{
                                var badge = doc.Status switch
                                {
                                    "indexed" => "success",
                                    "failed" => "danger",
                                    "processing" => "warning",
                                    _ => "secondary"
                                };
                            }
                            <span class="badge bg-@badge">@doc.Status</span>
                            @if (doc.Status == "failed" && !string.IsNullOrEmpty(doc.ErrorMsg))
                            {
                                <div class="small text-danger">@doc.ErrorMsg</div>
                            }
                        </td>
                        <td>
                            @doc.ChunkCount
                            @if (doc.Status == "indexed" && doc.ChunkCount == 0)
                            {
                                <span class="badge bg-warning text-dark ms-1">needs re-index</span>
                            }
                        </td>
                        <td>@(doc.CreatedAt?.ToString("g") ?? "—")</td>
                        <td>@(doc.IndexedAt?.ToString("g") ?? "—")</td>
                        <td class="text-nowrap">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@doc.Id">View</a>
                            @if (Model.CanDelete)
                            {
                                <form asp-action="Delete" asp-route-id="@doc.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this document?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
