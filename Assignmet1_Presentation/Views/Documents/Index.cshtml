@model DocumentListViewModel
@{
    ViewData["Title"] = "Documents";
}

<section class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="hero-badge mb-3">Document library</div>
            <h1 class="page-title">Subject library</h1>
            <p class="page-subtitle">Browse every subject that already has content in the system.</p>
        </div>
        @if (Model.CanCreateSubject)
        {
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" asp-controller="Subjects" asp-action="Create">New subject</a>
            </div>
        }
    </div>
</section>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success">@success</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

@if (!Model.Subjects.Any())
{
    <div class="content-panel text-center py-5">
        <h3 class="h5 mb-2">No subjects yet</h3>
        <p class="page-subtitle mb-0">Create the first subject to start organizing indexed documents.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var subject in Model.Subjects)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <a class="surface-card d-block h-100 text-decoration-none text-reset" asp-controller="Subjects" asp-action="Details" asp-route-id="@subject.Id">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <div class="hero-badge mb-2">Subject</div>
                            <h3 class="h5 mb-1">@subject.Code</h3>
                            <div class="page-subtitle mb-0">@subject.Name</div>
                        </div>
                        <span class="status-chip badge-soft">@subject.IndexedDocumentCount indexed</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(subject.Description))
                    {
                        <p class="text-white-50 mb-3">@subject.Description</p>
                    }

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="status-chip badge-soft">@subject.ChapterCount chapters</span>
                        <span class="status-chip badge-soft">@subject.DocumentCount docs</span>
                    </div>

                    <div class="d-flex justify-content-end">
                        <span class="btn btn-outline-light btn-sm">Open</span>
                    </div>
                </a>
            </div>
        }
    </div>
}
