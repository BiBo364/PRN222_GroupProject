@model PaymentAdminIndexViewModel
@using Assignmet1_Presentation.Constants
@{
    ViewData["Title"] = "Giao dich MoMo";
    string StatusLabel(string status) => status switch
    {
        PaymentStatuses.MomoPending => "Dang cho callback",
        PaymentStatuses.Approved => "Thanh cong",
        PaymentStatuses.Rejected => "That bai",
        _ => "Dang xu ly"
    };
    string StatusBadge(string status) => status switch
    {
        PaymentStatuses.MomoPending => "bg-info text-dark",
        PaymentStatuses.Approved => "bg-success",
        PaymentStatuses.Rejected => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

<section class="page-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="hero-badge mb-3">Admin workflow</div>
            <h1 class="page-title">Lich su giao dich MoMo</h1>
            <p class="page-subtitle mb-0">@Model.PendingCount giao dich dang doi MoMo xac nhan</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-light filter-chip @(Model.StatusFilter is null ? "active" : "")" asp-action="Index">Tat ca</a>
            <a class="btn btn-outline-warning filter-chip @(Model.StatusFilter == PaymentStatuses.Pending ? "active" : "")" asp-action="Index" asp-route-status="@PaymentStatuses.Pending">Dang xu ly</a>
            <a class="btn btn-outline-success filter-chip @(Model.StatusFilter == PaymentStatuses.Approved ? "active" : "")" asp-action="Index" asp-route-status="@PaymentStatuses.Approved">Thanh cong</a>
            <a class="btn btn-outline-danger filter-chip @(Model.StatusFilter == PaymentStatuses.Rejected ? "active" : "")" asp-action="Index" asp-route-status="@PaymentStatuses.Rejected">That bai</a>
        </div>
    </div>
</section>

@if (!Model.Tickets.Any())
{
    <div class="content-panel text-center py-5">Chua co giao dich nao.</div>
}
else
{
    <div class="surface-card p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nguoi dung</th>
                        <th>Goi</th>
                        <th>So tien</th>
                        <th>Ma don</th>
                        <th>Trang thai</th>
                        <th>Ngay tao</th>
                        <th>Ghi chu</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model.Tickets)
                    {
                        <tr>
                            <td>@ticket.Id</td>
                            <td>
                                <strong>@(ticket.FullName ?? ticket.Username)</strong><br />
                                <small class="text-muted">@ticket.Email</small>
                            </td>
                            <td>@ticket.PlanName</td>
                            <td>@ticket.Amount.ToString("N0") d</td>
                            <td>@(string.IsNullOrWhiteSpace(ticket.TransferReference) ? "-" : ticket.TransferReference)</td>
                            <td><span class="status-chip @StatusBadge(ticket.Status)">@StatusLabel(ticket.Status)</span></td>
                            <td>@(ticket.CreatedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(ticket.AdminNote))
                                {
                                    <div>@ticket.AdminNote</div>
                                }
                                else if (ticket.Status == PaymentStatuses.MomoPending)
                                {
                                    <small class="text-muted">He thong dang doi IPN/callback tu MoMo.</small>
                                }
                                else
                                {
                                    <small class="text-muted">-</small>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
