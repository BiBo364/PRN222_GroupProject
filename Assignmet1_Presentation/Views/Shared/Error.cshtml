@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="page-hero">
    <div class="hero-badge mb-3">Something went wrong</div>
    <h1 class="page-title text-danger">Error</h1>
    <p class="page-subtitle">An error occurred while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <div class="mini-panel mt-4">
            <div class="stat-label">Request ID</div>
            <div class="fw-semibold">@Model.RequestId</div>
        </div>
    }
</div>
