<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RAG Edu Hub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    @{
        var isLoggedIn = Context.Session.GetInt32("UserId") is not null;
        var forcePasswordChange = string.Equals(Context.Session.GetString("ForcePasswordChange"), "true", StringComparison.OrdinalIgnoreCase);
    }
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark app-nav">
            <div class="container app-shell">
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">RAG</span>
                    <span class="brand-text">Edu Hub</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 app-nav-links">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chu</a></li>
                        @if (isLoggedIn && !forcePasswordChange)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Documents" asp-action="Index">Tai lieu</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Chat" asp-action="Index">Chat AI</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Subscription" asp-action="Index">Goi hoc</a></li>
                            @if (Context.Session.GetInt32("RoleId") is int rId && rId == 1)
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Subjects" asp-action="Manage">Quan ly mon hoc</a></li>
                            }
                            @if (Context.Session.GetInt32("RoleId") is int roleId && roleId == 1)
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                        Quan tri
                                    </a>
                                    <ul class="dropdown-menu" style="background:#0d172a;border:1px solid rgba(255,255,255,.1)">
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Index"
                                               style="color:#eaf0ff">Quan ly nguoi dung</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="ImportUsers"
                                               style="color:#eaf0ff">Import nguoi dung</a>
                                        </li>
                                        <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1)" /></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="PaymentAdmin" asp-action="Index"
                                               style="color:#eaf0ff">Giao dich MoMo</a>
                                        </li>
                                    </ul>
                                </li>
                            }
                        }
                        else if (isLoggedIn && forcePasswordChange)
                        {
                            <li class="nav-item">
                                <span class="nav-link force-password-nav">Hoan tat doi mat khau de tiep tuc</span>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3 app-nav-meta">
                        @if (isLoggedIn)
                        {
                            <div class="dropdown">
                                <button class="user-chip dropdown-toggle border-0 bg-transparent"
                                        data-bs-toggle="dropdown" style="cursor:pointer">
                                    <span class="user-chip-label">Da dang nhap</span>
                                    <strong>@Context.Session.GetString("FullName")</strong>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end"
                                    style="background:#0d172a;border:1px solid rgba(255,255,255,.1);min-width:200px">
                                    <li class="px-3 py-2">
                                        <div style="font-size:.75rem;color:#64748b">Tai khoan</div>
                                        <div class="fw-semibold" style="font-size:.9rem">@Context.Session.GetString("FullName")</div>
                                    </li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1)" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"
                                           style="color:#eaf0ff">Doi mat khau</a>
                                    </li>
                                    <li><hr class="dropdown-divider" style="border-color:rgba(255,255,255,.1)" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Logout"
                                           style="color:#f87171">Dang xuat</a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Login">Dang nhap</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="app-main">
        <div class="container app-shell">
            @if (TempData["Success"] is string successMsg)
            {
                <div class="alert alert-success d-flex align-items-center gap-2 mb-4" role="alert">
                    <span>OK</span> @successMsg
                </div>
            }
            @if (TempData["Warning"] is string warningMsg)
            {
                <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
                    <span>!</span> @warningMsg
                </div>
            }
            @if (TempData["Error"] is string errorMsg)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
                    <span>X</span> @errorMsg
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="container app-shell d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
            <span>&copy; 2026 - RAG Edu Hub</span>
            <a asp-controller="Home" asp-action="Privacy">Chinh sach rieng tu</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
