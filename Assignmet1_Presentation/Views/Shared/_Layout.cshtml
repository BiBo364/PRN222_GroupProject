<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RAG Edu Hub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-body">
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark app-nav">
            <div class="container app-shell">
                <a class="navbar-brand app-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">RAG</span>
                    <span class="brand-text">Edu Hub</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 app-nav-links">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                        @if (Context.Session.GetInt32("UserId") is not null)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Documents" asp-action="Index">Documents</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Chat" asp-action="Index">Chat</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Subscription" asp-action="Index">Subscription</a></li>
                            @if (Context.Session.GetInt32("RoleId") is int roleId && (roleId == 1 || roleId == 2))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="PaymentAdmin" asp-action="Index">Admin</a></li>
                            }
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3 app-nav-meta">
                        @if (Context.Session.GetInt32("UserId") is not null)
                        {
                            <div class="user-chip">
                                <span class="user-chip-label">Signed in</span>
                                <strong>@Context.Session.GetString("FullName")</strong>
                            </div>
                            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Logout">Logout</a>
                        }
                        else
                        {
                            <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="app-main">
        <div class="container app-shell">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="container app-shell d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
            <span>&copy; 2026 - RAG Edu Hub</span>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
