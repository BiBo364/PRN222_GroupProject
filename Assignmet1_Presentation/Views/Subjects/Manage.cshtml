@model List<SubjectListItemViewModel>
@using Assignmet1_Presentation.Models
@{
    ViewData["Title"] = "Quản lý môn học";
}

<div class="d-flex flex-column gap-4">

    @* ── HERO ──────────────────────────────────────────────── *@
    <div class="page-hero d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
        <div>
            <div class="hero-badge mb-2">📚 Giảng viên</div>
            <h1 class="page-title mb-1">Quản lý môn học</h1>
            <p class="page-subtitle">Tạo, cập nhật, và xóa thông tin các môn học.</p>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
            <a asp-action="Create" class="btn btn-primary">
                ➕ Thêm môn học
            </a>
        </div>
    </div>

    @* ── ALERT MESSAGES ───────────────────────────────────── *@
    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-0" role="alert">
            <span>✅</span> @success
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-0" role="alert">
            <span>❌</span> @error
        </div>
    }

    @* ── TABLE ────────────────────────────────────────────── *@
    <div class="surface-card p-0 overflow-hidden">
        <div class="px-4 py-3 d-flex align-items-center justify-content-between" style="border-bottom:1px solid rgba(255,255,255,.08)">
            <h2 class="h6 mb-0 fw-semibold">Danh sách môn học (@Model.Count)</h2>
        </div>

        @if (Model.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <div style="font-size:3rem">📚</div>
                <p class="mt-2">Chưa có môn học nào được tạo.</p>
                <a asp-action="Create" class="btn btn-outline-primary mt-2">Tạo môn học đầu tiên</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th class="ps-4">Mã môn</th>
                            <th>Tên môn</th>
                            <th>Tài liệu</th>
                            <th class="pe-4 text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var subject in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold">@subject.Code</div>
                                </td>
                                <td>
                                    <div>@subject.Name</div>
                                    <div class="text-muted small">@subject.Description</div>
                                </td>
                                <td>
                                    <span class="status-chip" style="background:rgba(96,165,250,.1);border-color:rgba(96,165,250,.25);color:#93c5fd">
                                        📄 @subject.DocumentCount
                                    </span>
                                </td>
                                <td class="pe-4 text-end">
                                    <a asp-action="Details" asp-route-id="@subject.Id" class="btn btn-sm btn-outline-info" title="Xem chi tiết & Upload" style="font-size:.78rem;padding:.3rem .7rem;border-radius:.5rem">
                                        👁️ Xem
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@subject.Id" class="btn btn-sm btn-outline-primary" style="font-size:.78rem;padding:.3rem .7rem;border-radius:.5rem">
                                        ✏️ Sửa
                                    </a>
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@subject.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" 
                                                style="font-size:.78rem;padding:.3rem .7rem;border-radius:.5rem"
                                                onclick="return confirm('Bạn có chắc chắn muốn xóa môn học @subject.Code này không? (Không thể xóa nếu đã có tài liệu hoặc sinh viên)')">
                                            🗑️ Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
