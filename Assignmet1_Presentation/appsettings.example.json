{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=rag_edu;Trusted_Connection=True;Encrypt=True;TrustServerCertificate=True"
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-3.1-flash-lite",
    "EmbeddingModel": "gemini-embedding-001",
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta"
  },
  "Smtp": {
    "Enabled": false,
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "Username": "your-account@gmail.com",
    "Password": "your-app-password",
    "FromEmail": "your-account@gmail.com",
    "FromName": "RAG EDU",
    "LoginUrl": "https://localhost:5001/Account/Login"
  },
  "MoMo": {
    "PartnerCode": "MOMO",
    "AccessKey": "",
    "SecretKey": "",
    "Endpoint": "https://test-payment.momo.vn/v2/gateway/api/create",
    "IpnUrl": "https://your-domain.com/MoMoPayment/Ipn",
    "RedirectUrl": "https://your-domain.com/MoMoPayment/Return",
    "RequestType": "payWithMethod",
    "PartnerName": "RAG EDU",
    "StoreId": "RagEduStore",
    "OrderGroupId": "",
    "AutoCapture": true,
    "Lang": "vi"
  },
  "SubscriptionQuota": {
    "FreeQuestionLimit": 5,
    "FreeQuotaWindowHours": 24
  },
  "Chunking": {
    // Số từ tối đa trong mỗi chunk (không cần sửa database).
    // Tăng lên → chunk chứa nhiều ngữ cảnh hơn (tốt cho câu hỏi tổng quát).
    // Giảm xuống → chunk nhỏ hơn, câu trả lời chính xác hơn (tốt cho chi tiết).
    "MaxWordsPerChunk": 250,
    // Số từ được lặp lại giữa hai chunk liền kề (overlap).
    // Giúp tránh mất ngữ cảnh tại ranh giới chunk.
    // Không nên quá 20% của MaxWordsPerChunk.
    "OverlapWords": 40,
    // Số chunk tối đa được truy xuất cho mỗi câu hỏi (Top-K).
    // Tăng nếu câu trả lời thường thiếu thông tin; giảm để tiết kiệm token Gemini.
    "TopK": 4,
    // Kết hợp vector similarity + keyword matching khi truy xuất.
    // true = chính xác hơn, false = nhanh hơn (không cần tắt trên server yếu).
    "UseHybridRerank": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
